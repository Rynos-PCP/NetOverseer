  <data name="Section_HideGeoDbWarning.Text" xml:space="preserve">
    <value>Hide GeoLite2 warning</value>
  </data>
  <data name="HideGeoDbWarning_Desc.Text" xml:space="preserve">
    <value>Hides the notice shown when the GeoLite2 database was not found.</value>
  </data>
  <data name="HideGeoDbWarningSwitch.OnContent" xml:space="preserve">
