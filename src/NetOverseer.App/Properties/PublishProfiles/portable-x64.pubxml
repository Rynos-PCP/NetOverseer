<?xml version="1.0" encoding="utf-8"?>
<!--
  Publish profile: portable self-contained x64 ZIP build
  Usage:
    dotnet publish src/NetOverseer.App -p:PublishProfile=portable-x64
  Or via MSBuild:
    msbuild src/NetOverseer.App /p:DeployOnBuild=true /p:PublishProfile=portable-x64
-->
<Project>
  <PropertyGroup>
    <Configuration>Release</Configuration>
    <Platform>x64</Platform>
    <PublishDir>$(MSBuildThisFileDirectory)..\..\publish\portable-x64\</PublishDir>
    <PublishProtocol>FileSystem</PublishProtocol>
    <TargetFramework>net8.0-windows10.0.19041.0</TargetFramework>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <SelfContained>true</SelfContained>
    <PublishSingleFile>false</PublishSingleFile>
    <WindowsPackageType>None</WindowsPackageType>

    <!-- Trim unused assemblies to reduce size (safe for WinUI 3 unpackaged) -->
    <PublishTrimmed>false</PublishTrimmed>

    <!-- ReadyToRun pre-compilation for faster startup -->
    <PublishReadyToRun>true</PublishReadyToRun>
  </PropertyGroup>
</Project>
