<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="NetOverseer.App.Views.HistoryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:NetOverseer.App.ViewModels">

    <Page.Resources>
        <Style x:Key="HistorySurfaceCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}"/>
            <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="16"/>
        </Style>

        <Style x:Key="HistoryMetricCardStyle" TargetType="Border" BasedOn="{StaticResource HistorySurfaceCardStyle}">
            <Setter Property="MinHeight" Value="118"/>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Padding="16,12,16,12"
                Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}"
                BorderBrush="{ThemeResource SystemControlForegroundBaseLowBrush}"
                BorderThickness="0,0,0,1">
            <Grid ColumnSpacing="16" RowSpacing="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Grid.Column="0" Spacing="2">
                    <TextBlock Text="Verlauf" Style="{ThemeResource TitleTextBlockStyle}"/>
                    <TextBlock Text="{x:Bind ViewModel.RangeSummaryText, Mode=OneWay}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               TextWrapping="WrapWholeWords"/>
                </StackPanel>

                <Button Grid.Row="0" Grid.Column="1" Command="{x:Bind ViewModel.RefreshCommand}"
                        VerticalAlignment="Center" Style="{ThemeResource AccentButtonStyle}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE72C;" FontSize="14"/>
                        <TextBlock Text="Aktualisieren"/>
                    </StackPanel>
                </Button>

                <StackPanel Grid.Row="1" Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <TextBlock Text="Zeitraum:" VerticalAlignment="Center"
                               Foreground="{ThemeResource SystemControlForegroundBaseHighBrush}"/>
                    <RadioButton x:Name="RbHour" Content="Letzte Stunde" Tag="LastHour" GroupName="TimeRange" Checked="TimeRange_Checked"/>
                    <RadioButton x:Name="RbDay" Content="24 Stunden" Tag="Last24Hours" GroupName="TimeRange" Checked="TimeRange_Checked" IsChecked="True"/>
                    <RadioButton x:Name="RbWeek" Content="7 Tage" Tag="LastWeek" GroupName="TimeRange" Checked="TimeRange_Checked"/>
                </StackPanel>

                <TextBox Grid.Row="1" Grid.Column="1"
                         Text="{x:Bind ViewModel.AppFilter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         PlaceholderText="Anwendung filtern …"
                         VerticalAlignment="Center"
                         MinWidth="320" MaxWidth="420"/>
            </Grid>
        </Border>

        <Pivot Grid.Row="1" Margin="12,12,12,0">

            <PivotItem Header="Aktivitaet">
                <Grid>
                    <ProgressRing IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                                  Width="48" Height="48"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"
                                  Visibility="{x:Bind ViewModel.LoadingVisibility, Mode=OneWay}"/>

                    <StackPanel Visibility="{x:Bind ViewModel.EmptyVisibility, Mode=OneWay}"
                                HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
                        <FontIcon Glyph="&#xE81C;" FontSize="48"
                                  Foreground="{ThemeResource SystemControlForegroundBaseLowBrush}"/>
                        <TextBlock Text="Keine Verbindungen im gewählten Zeitraum."
                                   Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>

                    <ScrollViewer Visibility="{x:Bind ViewModel.HasDataVisibility, Mode=OneWay}"
                                  VerticalScrollBarVisibility="Auto">
                        <StackPanel Padding="0,4,0,16" Spacing="16">
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Style="{StaticResource HistoryMetricCardStyle}">
                                    <StackPanel Spacing="6">
                                        <TextBlock Text="Aktive Apps" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="13"/>
                                        <TextBlock Text="{x:Bind ViewModel.ActiveAppsRange, Mode=OneWay}" Style="{ThemeResource TitleTextBlockStyle}"/>
                                        <TextBlock Text="mit Aktivitaet im gewaehlten Zeitraum" TextWrapping="WrapWholeWords" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12"/>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="1" Style="{StaticResource HistoryMetricCardStyle}">
                                    <StackPanel Spacing="6">
                                        <TextBlock Text="Verbindungen" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="13"/>
                                        <TextBlock Text="{x:Bind ViewModel.TotalConnectionsRange, Mode=OneWay}" Style="{ThemeResource TitleTextBlockStyle}"/>
                                        <TextBlock Text="gesamt im aktuellen Fenster" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12"/>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="2" Style="{StaticResource HistoryMetricCardStyle}">
                                    <StackPanel Spacing="6">
                                        <TextBlock Text="Datenvolumen" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="13"/>
                                        <TextBlock Text="{x:Bind ViewModel.TotalDataRangeDisplay, Mode=OneWay}" Style="{ThemeResource TitleTextBlockStyle}"/>
                                        <TextBlock Text="Upload plus Download" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12"/>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="3" Style="{StaticResource HistoryMetricCardStyle}">
                                    <StackPanel Spacing="6">
                                        <TextBlock Text="Auffaellige Apps" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="13"/>
                                        <TextBlock Text="{x:Bind ViewModel.SuspiciousAppsRange, Mode=OneWay}" Style="{ThemeResource TitleTextBlockStyle}" Foreground="{ThemeResource SystemFillColorCriticalBrush}"/>
                                        <TextBlock Text="mit niedriger Reputation" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12"/>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="4" Style="{StaticResource HistoryMetricCardStyle}">
                                    <StackPanel Spacing="6">
                                        <TextBlock Text="Staerkste App" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="13"/>
                                        <TextBlock Text="{x:Bind ViewModel.BusiestAppName, Mode=OneWay}" Style="{ThemeResource BodyStrongTextBlockStyle}" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{x:Bind ViewModel.BusiestAppTrafficDisplay, Mode=OneWay}" FontSize="20" FontWeight="SemiBold"/>
                                        <TextBlock Text="{x:Bind ViewModel.LastRefreshDisplay, Mode=OneWay}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12"/>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <Grid ColumnSpacing="16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2.2*"/>
                                    <ColumnDefinition Width="1.2*"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Style="{StaticResource HistorySurfaceCardStyle}">
                                    <StackPanel Spacing="12">
                                        <StackPanel Spacing="2">
                                            <TextBlock Text="Zeitleiste nach Anwendung" Style="{ThemeResource SubtitleTextBlockStyle}"/>
                                            <TextBlock Text="Sortiert nach Verbindungen und Datenvolumen. Ein Klick auf eine Zeile oeffnet die Detailansicht." Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="WrapWholeWords"/>
                                        </StackPanel>

                                        <ItemsControl ItemsSource="{x:Bind ViewModel.AppActivities, Mode=OneWay}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="vm:AppActivityViewModel">
                                                    <Border Margin="0,0,0,8" Padding="14,12" CornerRadius="10"
                                                            Background="{ThemeResource LayerFillColorDefaultBrush}"
                                                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                                            BorderThickness="1"
                                                            PointerPressed="AppRow_PointerPressed"
                                                            Tag="{x:Bind ProcessName, Mode=OneTime}">
                                                        <Grid RowSpacing="10" ColumnSpacing="14">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="240"/>
                                                            </Grid.ColumnDefinitions>
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition Height="Auto"/>
                                                                <RowDefinition Height="Auto"/>
                                                            </Grid.RowDefinitions>

                                                            <FontIcon Grid.RowSpan="2" Grid.Column="0" Glyph="&#xE80F;" FontSize="20"
                                                                      VerticalAlignment="Top"
                                                                      Visibility="{x:Bind NormalIconVisibility, Mode=OneTime}"/>
                                                            <FontIcon Grid.RowSpan="2" Grid.Column="0" Glyph="&#xE7BA;" FontSize="20"
                                                                      VerticalAlignment="Top"
                                                                      Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                                                      Visibility="{x:Bind SuspiciousIconVisibility, Mode=OneTime}"/>

                                                            <StackPanel Grid.Column="1" Grid.Row="0" Spacing="3">
                                                                <TextBlock Text="{x:Bind ProcessName, Mode=OneTime}" Style="{ThemeResource BodyStrongTextBlockStyle}" TextTrimming="CharacterEllipsis"/>
                                                                <TextBlock Text="{x:Bind ExecutablePath, Mode=OneTime}" FontFamily="Cascadia Code,Consolas,Courier New" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis"/>
                                                            </StackPanel>

                                                            <Border Grid.Column="2" Grid.RowSpan="2" Padding="10,8" CornerRadius="8" Background="{ThemeResource SystemControlBackgroundChromeMediumBrush}">
                                                                <StackPanel Spacing="6">
                                                                    <TextBlock Text="Aktivitaetsprofil" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12"/>
                                                                    <ItemsControl ItemsSource="{x:Bind Buckets, Mode=OneTime}">
                                                                        <ItemsControl.ItemsPanel>
                                                                            <ItemsPanelTemplate>
                                                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom"/>
                                                                            </ItemsPanelTemplate>
                                                                        </ItemsControl.ItemsPanel>
                                                                        <ItemsControl.ItemTemplate>
                                                                            <DataTemplate x:DataType="vm:TimeBucketViewModel">
                                                                                <Rectangle Width="7"
                                                                                           Height="{x:Bind BarHeight, Mode=OneTime}"
                                                                                           Margin="1,0"
                                                                                           Fill="{ThemeResource AccentFillColorDefaultBrush}"
                                                                                           Opacity="{x:Bind BarOpacity, Mode=OneTime}"
                                                                                           RadiusX="2" RadiusY="2"
                                                                                           VerticalAlignment="Bottom"
                                                                                           ToolTipService.ToolTip="{x:Bind TooltipText, Mode=OneTime}"/>
                                                                            </DataTemplate>
                                                                        </ItemsControl.ItemTemplate>
                                                                    </ItemsControl>
                                                                </StackPanel>
                                                            </Border>

                                                            <StackPanel Grid.Column="1" Grid.Row="1" Orientation="Horizontal" Spacing="8">
                                                                <Border Background="{ThemeResource AccentFillColorDefaultBrush}" CornerRadius="999" Padding="10,4">
                                                                    <TextBlock Text="{x:Bind ConnectionCount, Mode=OneTime}" Foreground="White" FontWeight="SemiBold" FontSize="12"/>
                                                                </Border>
                                                                <Border Background="{ThemeResource SystemControlBackgroundChromeMediumBrush}" CornerRadius="999" Padding="10,4">
                                                                    <TextBlock Text="{x:Bind BytesSentDisplay, Mode=OneTime}" FontSize="12"/>
                                                                </Border>
                                                                <Border Background="{ThemeResource SystemControlBackgroundChromeMediumBrush}" CornerRadius="999" Padding="10,4">
                                                                    <TextBlock Text="{x:Bind BytesRecvDisplay, Mode=OneTime}" FontSize="12"/>
                                                                </Border>
                                                                <Border Background="{ThemeResource SystemControlBackgroundChromeMediumBrush}" CornerRadius="999" Padding="10,4">
                                                                    <TextBlock Text="{x:Bind LastSeenDisplay, Mode=OneTime}" FontSize="12"/>
                                                                </Border>
                                                            </StackPanel>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>

                                <StackPanel Grid.Column="1" Spacing="16">
                                    <Border Style="{StaticResource HistorySurfaceCardStyle}">
                                        <StackPanel Spacing="12">
                                            <StackPanel Spacing="2">
                                                <TextBlock Text="Top-Apps im Zeitraum" Style="{ThemeResource SubtitleTextBlockStyle}"/>
                                                <TextBlock Text="Die aktivsten Anwendungen im aktuell gewaehlten Fenster." Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="WrapWholeWords"/>
                                            </StackPanel>

                                            <ItemsControl ItemsSource="{x:Bind ViewModel.TopRangeActivities, Mode=OneWay}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate x:DataType="vm:AppActivityViewModel">
                                                        <Border Margin="0,0,0,8" Padding="12,10" CornerRadius="8" Background="{ThemeResource LayerFillColorDefaultBrush}">
                                                            <Grid ColumnSpacing="10">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                </Grid.ColumnDefinitions>
                                                                <StackPanel Grid.Column="0" Spacing="2">
                                                                    <TextBlock Text="{x:Bind ProcessName, Mode=OneTime}" Style="{ThemeResource BodyStrongTextBlockStyle}" TextTrimming="CharacterEllipsis"/>
                                                                    <TextBlock Text="{x:Bind LastSeenDisplay, Mode=OneTime}" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                                                </StackPanel>
                                                                <StackPanel Grid.Column="1" Spacing="2" HorizontalAlignment="Right">
                                                                    <TextBlock Text="{x:Bind ConnectionCount, Mode=OneTime}" HorizontalAlignment="Right" FontSize="13" FontWeight="SemiBold"/>
                                                                    <TextBlock Text="{x:Bind BytesRecvDisplay, Mode=OneTime}" HorizontalAlignment="Right" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                                                </StackPanel>
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>

                                    <Border Style="{StaticResource HistorySurfaceCardStyle}">
                                        <StackPanel Spacing="12">
                                            <StackPanel Spacing="2">
                                                <TextBlock Text="Frische Warnhinweise" Style="{ThemeResource SubtitleTextBlockStyle}"/>
                                                <TextBlock Text="Auffaellige Ziele mit schlechter Reputation im gleichen Zeitraum." Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="WrapWholeWords"/>
                                            </StackPanel>

                                            <ItemsControl ItemsSource="{x:Bind ViewModel.RangeSuspiciousConnections, Mode=OneWay}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate x:DataType="vm:SuspiciousConnectionViewModel">
                                                        <Border Margin="0,0,0,8" Padding="12,10" CornerRadius="8" Background="{ThemeResource LayerFillColorDefaultBrush}" BorderBrush="{ThemeResource SystemFillColorCriticalBrush}" BorderThickness="1">
                                                            <StackPanel Spacing="4">
                                                                <TextBlock Text="{x:Bind ProcessName, Mode=OneTime}" Style="{ThemeResource BodyStrongTextBlockStyle}" TextTrimming="CharacterEllipsis"/>
                                                                <TextBlock Text="{x:Bind RemoteIp, Mode=OneTime}" FontFamily="Cascadia Code,Consolas,Courier New" FontSize="12"/>
                                                                <Grid ColumnSpacing="8">
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="*"/>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                    </Grid.ColumnDefinitions>
                                                                    <TextBlock Grid.Column="0" Text="{x:Bind TimestampDisplay, Mode=OneTime}" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                                                    <TextBlock Grid.Column="1" Text="{x:Bind ReputationDisplay, Mode=OneTime}" FontSize="12" FontWeight="SemiBold" Foreground="{ThemeResource SystemFillColorCriticalBrush}"/>
                                                                </Grid>
                                                            </StackPanel>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </PivotItem>

            <PivotItem Header="7-Tage-Bericht">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Padding="0,4,0,16" Spacing="16">

                        <ProgressRing IsActive="{x:Bind ViewModel.WeeklyIsLoading, Mode=OneWay}"
                                      Width="40" Height="40" HorizontalAlignment="Center"
                                      Visibility="{x:Bind ViewModel.WeeklyLoadingVisible, Mode=OneWay}"/>

                        <Border Style="{StaticResource HistorySurfaceCardStyle}">
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Spacing="4">
                                    <TextBlock Text="Wochenbericht" Style="{ThemeResource TitleTextBlockStyle}"/>
                                    <TextBlock Text="Verdichtete 7-Tage-Uebersicht fuer Verkehrsaufkommen, datenintensive Anwendungen und auffaellige Ziele." Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="WrapWholeWords"/>
                                </StackPanel>
                                <Button Grid.Column="1" Command="{x:Bind ViewModel.ExportWeeklyReportCommand}" HorizontalAlignment="Right" VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon Glyph="&#xE896;" FontSize="14"/>
                                        <TextBlock Text="Als HTML exportieren"/>
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </Border>

                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Style="{StaticResource HistoryMetricCardStyle}">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="{x:Bind ViewModel.TotalConnectionsWeek, Mode=OneWay}"
                                               Style="{ThemeResource TitleTextBlockStyle}"/>
                                    <TextBlock Text="Verbindungen (7 Tage)"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               FontSize="13"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="1" Style="{StaticResource HistoryMetricCardStyle}">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="{x:Bind ViewModel.TotalDataWeekDisplay, Mode=OneWay}"
                                               Style="{ThemeResource TitleTextBlockStyle}"/>
                                    <TextBlock Text="Datenvolumen gesamt"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               FontSize="13"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2" Style="{StaticResource HistoryMetricCardStyle}">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="{x:Bind ViewModel.SuspiciousCountWeek, Mode=OneWay}"
                                               Style="{ThemeResource TitleTextBlockStyle}"
                                               Foreground="{ThemeResource SystemFillColorCriticalBrush}"/>
                                    <TextBlock Text="Apps mit verdächtigen Verbindungen"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               FontSize="13"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Grid ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Style="{StaticResource HistorySurfaceCardStyle}">
                                <StackPanel Spacing="12">
                                    <TextBlock Text="Top 5 datenintensive Anwendungen" Style="{ThemeResource SubtitleTextBlockStyle}"/>
                                    <ItemsControl ItemsSource="{x:Bind ViewModel.TopApps, Mode=OneWay}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="vm:WeeklyAppEntryViewModel">
                                                <Border Padding="12,10" Margin="0,0,0,8" CornerRadius="8" Background="{ThemeResource LayerFillColorDefaultBrush}">
                                                    <Grid ColumnSpacing="12">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="32"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0" Text="{x:Bind Rank, Mode=OneTime}" Style="{ThemeResource TitleTextBlockStyle}" Foreground="{ThemeResource TextFillColorTertiaryBrush}" VerticalAlignment="Center"/>
                                                        <StackPanel Grid.Column="1" Spacing="2">
                                                            <TextBlock Text="{x:Bind ProcessName, Mode=OneTime}" Style="{ThemeResource BodyStrongTextBlockStyle}" TextTrimming="CharacterEllipsis"/>
                                                            <TextBlock Text="{x:Bind ExecutablePath, Mode=OneTime}" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis"/>
                                                        </StackPanel>
                                                        <StackPanel Grid.Column="2" VerticalAlignment="Center" Spacing="2" Margin="12,0,0,0">
                                                            <TextBlock Text="{x:Bind BytesSentDisplay, Mode=OneTime}" FontSize="13" FontWeight="SemiBold" HorizontalAlignment="Right"/>
                                                            <TextBlock Text="{x:Bind BytesRecvDisplay, Mode=OneTime}" FontSize="12" HorizontalAlignment="Right" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="1" Style="{StaticResource HistorySurfaceCardStyle}">
                                <StackPanel Spacing="12">
                                    <TextBlock Text="Top 5 verdaechtige Verbindungen" Style="{ThemeResource SubtitleTextBlockStyle}"/>
                                    <ItemsControl ItemsSource="{x:Bind ViewModel.SuspiciousConnections, Mode=OneWay}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="vm:SuspiciousConnectionViewModel">
                                                <Border Padding="12,10" Margin="0,0,0,8" CornerRadius="8" Background="{ThemeResource LayerFillColorDefaultBrush}" BorderBrush="{ThemeResource SystemFillColorCriticalBrush}" BorderThickness="1">
                                                    <Grid ColumnSpacing="12">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel Grid.Column="0" VerticalAlignment="Center" Spacing="2">
                                                            <TextBlock Text="{x:Bind ProcessName, Mode=OneTime}" Style="{ThemeResource BodyStrongTextBlockStyle}" TextTrimming="CharacterEllipsis"/>
                                                            <TextBlock Text="{x:Bind TimestampDisplay, Mode=OneTime}" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                                        </StackPanel>
                                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                                            <TextBlock Text="{x:Bind RemoteIp, Mode=OneTime}" FontFamily="Cascadia Code,Consolas,Courier New" FontSize="13"/>
                                                            <TextBlock Text="{x:Bind GeoCountry, Mode=OneTime}" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                                        </StackPanel>
                                                        <Border Grid.Column="2" Background="{ThemeResource SystemFillColorCriticalBrush}" CornerRadius="4" Padding="8,4" VerticalAlignment="Center">
                                                            <TextBlock Text="{x:Bind ReputationDisplay, Mode=OneTime}" FontSize="12" FontWeight="SemiBold" Foreground="White"/>
                                                        </Border>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </Grid>

                    </StackPanel>
                </ScrollViewer>
            </PivotItem>
        </Pivot>
    </Grid>
</Page>
