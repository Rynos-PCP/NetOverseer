<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="NetOverseer.App.Views.ConnectionDetailDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Verbindungsdetails"
    CloseButtonText="Schließen"
    DefaultButton="Close"
    MinWidth="520">

    <ScrollViewer MaxHeight="520" VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="20" Padding="0,4">

            <!-- ═══════ Prozess ═══════════════════════════════════════════ -->
            <StackPanel Spacing="8">
                <TextBlock Text="Anwendung"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="40"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Image x:Name="ProcessIcon"
                           Grid.Column="0"
                           Width="36" Height="36"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>

                    <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                        <TextBlock x:Name="ProcessDisplayNameText"
                                   Style="{StaticResource BodyStrongTextBlockStyle}"/>
                        <TextBlock x:Name="ProcessExecutableText"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   TextWrapping="Wrap"
                                   IsTextSelectionEnabled="True"/>
                        <TextBlock x:Name="ProcessPidText"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                    </StackPanel>
                </Grid>
            </StackPanel>

            <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}"/>

            <!-- ═══════ Verbindung ════════════════════════════════════════ -->
            <StackPanel Spacing="8">
                <TextBlock Text="Verbindung"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                <Grid ColumnSpacing="8" RowSpacing="6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Protokoll"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <TextBlock x:Name="ProtoText" Grid.Row="0" Grid.Column="1"
                               FontWeight="SemiBold" IsTextSelectionEnabled="True"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Lokal"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <TextBlock x:Name="LocalText" Grid.Row="1" Grid.Column="1"
                               FontFamily="Cascadia Code,Consolas,Courier New"
                               IsTextSelectionEnabled="True"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Remote"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <TextBlock x:Name="RemoteText" Grid.Row="2" Grid.Column="1"
                               FontFamily="Cascadia Code,Consolas,Courier New"
                               IsTextSelectionEnabled="True"/>

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Hostname"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <TextBlock x:Name="HostnameText" Grid.Row="3" Grid.Column="1"
                               IsTextSelectionEnabled="True"/>

                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Status"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <TextBlock x:Name="StatusText" Grid.Row="4" Grid.Column="1"/>
                </Grid>
            </StackPanel>

            <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}"/>

            <!-- ═══════ Geolocation ═══════════════════════════════════════ -->
            <StackPanel Spacing="8">
                <TextBlock Text="Geolocation"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                <Grid ColumnSpacing="8" RowSpacing="6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Land"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <TextBlock x:Name="CountryText" Grid.Row="0" Grid.Column="1"
                               IsTextSelectionEnabled="True"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Organisation"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <TextBlock x:Name="OrgText" Grid.Row="1" Grid.Column="1"
                               IsTextSelectionEnabled="True"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Kategorie"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <TextBlock x:Name="InfraText" Grid.Row="2" Grid.Column="1"/>
                </Grid>
            </StackPanel>

            <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}"/>

            <!-- ═══════ Reputation ════════════════════════════════════════ -->
            <StackPanel Spacing="8">
                <TextBlock Text="Reputation"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                <Grid ColumnSpacing="8" RowSpacing="6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Bewertung"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <TextBlock x:Name="RepText" Grid.Row="0" Grid.Column="1"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Quelle"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <TextBlock x:Name="RepSourceText" Grid.Row="1" Grid.Column="1"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                </Grid>
            </StackPanel>

            <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}"/>

            <!-- ═══════ Zeitstempel ═══════════════════════════════════════ -->
            <StackPanel Spacing="8">
                <TextBlock Text="Zeitstempel"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                <Grid ColumnSpacing="8" RowSpacing="6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Erste Aktivität"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <TextBlock x:Name="FirstSeenText" Grid.Row="0" Grid.Column="1"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Letzte Aktivität"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <TextBlock x:Name="LastSeenText" Grid.Row="1" Grid.Column="1"/>
                </Grid>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</ContentDialog>
