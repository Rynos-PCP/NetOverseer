<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="NetOverseer.App.Views.ApplicationsPage"
    x:Name="RootPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:NetOverseer.App.ViewModels">

    <Page.Resources>
        <vm:ApplicationColumnLayoutSource x:Key="AppColumnLayout"/>

        <Style x:Key="AppColumnSplitterStyle" TargetType="Border">
            <Setter Property="Width" Value="8"/>
            <Setter Property="VerticalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="ManipulationMode" Value="TranslateX"/>
        </Style>

        <Storyboard x:Key="AppDetailsSlideIn">
            <DoubleAnimation Storyboard.TargetName="AppDetailsTransform"
                             Storyboard.TargetProperty="X"
                             To="0" Duration="0:0:0.25">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="AppDetailsBackdrop"
                             Storyboard.TargetProperty="Opacity"
                             To="0.45" Duration="0:0:0.2"/>
        </Storyboard>

        <Storyboard x:Key="AppDetailsSlideOut">
            <DoubleAnimation Storyboard.TargetName="AppDetailsTransform"
                             Storyboard.TargetProperty="X"
                             To="520" Duration="0:0:0.2">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseIn"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="AppDetailsBackdrop"
                             Storyboard.TargetProperty="Opacity"
                             To="0" Duration="0:0:0.15"/>
        </Storyboard>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0"
              Padding="12,10"
              ColumnDefinitions="*,Auto,Auto,Auto"
              BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
              BorderThickness="0,0,0,1">

            <AutoSuggestBox
                Grid.Column="0"
                Width="360"
                QueryIcon="Find"
                PlaceholderText="Anwendung suchen (Name, Prozess, Pfad) …"
                HorizontalAlignment="Left"
                Text="{x:Bind ViewModel.SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

            <Button Grid.Column="1"
                    Margin="8,0,0,0"
                    Command="{x:Bind ViewModel.RefreshCommand}">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon Glyph="&#xE72C;" FontSize="14"/>
                    <TextBlock Text="Aktualisieren"/>
                </StackPanel>
            </Button>

            <ToggleSwitch Grid.Column="2"
                          Margin="10,0,0,0"
                          Header="Traffic-Metriken"
                          VerticalAlignment="Center"
                          IsOn="{x:Bind ViewModel.IsTrafficMetricsEnabled, Mode=TwoWay}"/>

            <TextBlock Grid.Column="3"
                       Margin="16,0,0,0"
                       VerticalAlignment="Center"
                       Text="{x:Bind ViewModel.StatusText, Mode=OneWay}"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
        </Grid>

        <Grid Grid.Row="1">
            <Grid Visibility="{x:Bind ViewModel.LoadingVisibility, Mode=OneWay}">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="10">
                    <ProgressRing IsActive="True" Width="38" Height="38"/>
                    <TextBlock Text="Lade Anwendungen …"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                </StackPanel>
            </Grid>

            <Grid Visibility="{x:Bind ViewModel.ContentVisibility, Mode=OneWay}">
                <Grid RowDefinitions="36,*">
                    <Border Grid.Row="0"
                            Background="{ThemeResource SystemControlBackgroundChromeMediumBrush}"
                            BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                            BorderThickness="0,0,0,1">
                        <Grid Margin="12,0,12,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="{Binding Layout.NameWidth, Source={StaticResource AppColumnLayout}, Mode=OneWay}"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="{Binding Layout.PathWidth, Source={StaticResource AppColumnLayout}, Mode=OneWay}"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="{Binding Layout.EffectiveUploadWidth, Source={StaticResource AppColumnLayout}, Mode=OneWay}"/>
                                <ColumnDefinition Width="{Binding Layout.UploadSplitterWidth, Source={StaticResource AppColumnLayout}, Mode=OneWay}"/>
                                <ColumnDefinition Width="{Binding Layout.EffectiveDownloadWidth, Source={StaticResource AppColumnLayout}, Mode=OneWay}"/>
                                <ColumnDefinition Width="{Binding Layout.DownloadSplitterWidth, Source={StaticResource AppColumnLayout}, Mode=OneWay}"/>
                                <ColumnDefinition Width="{Binding Layout.LastSeenWidth, Source={StaticResource AppColumnLayout}, Mode=OneWay}"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="{Binding Layout.TrustWidth, Source={StaticResource AppColumnLayout}, Mode=OneWay}"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="{Binding Layout.BlockWidth, Source={StaticResource AppColumnLayout}, Mode=OneWay}"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" Text="Anwendung" Style="{StaticResource CaptionTextBlockStyle}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <Border Grid.Column="1" Tag="NameWidth" Style="{StaticResource AppColumnSplitterStyle}" ManipulationDelta="AppColumnSplitter_ManipulationDelta" PointerEntered="AppColumnSplitter_PointerEntered" PointerExited="AppColumnSplitter_PointerExited">
                                <Rectangle Width="1" HorizontalAlignment="Center" Fill="{ThemeResource DividerStrokeColorDefaultBrush}"/>
                            </Border>

                            <TextBlock Grid.Column="2" Text="Pfad" Style="{StaticResource CaptionTextBlockStyle}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <Border Grid.Column="3" Tag="PathWidth" Style="{StaticResource AppColumnSplitterStyle}" ManipulationDelta="AppColumnSplitter_ManipulationDelta" PointerEntered="AppColumnSplitter_PointerEntered" PointerExited="AppColumnSplitter_PointerExited">
                                <Rectangle Width="1" HorizontalAlignment="Center" Fill="{ThemeResource DividerStrokeColorDefaultBrush}"/>
                            </Border>

                            <TextBlock Grid.Column="4" Text="Upload" Style="{StaticResource CaptionTextBlockStyle}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Visibility="{x:Bind ViewModel.TrafficColumnVisibility, Mode=OneWay}"/>
                            <Border Grid.Column="5" Tag="UploadWidth" Style="{StaticResource AppColumnSplitterStyle}" ManipulationDelta="AppColumnSplitter_ManipulationDelta" PointerEntered="AppColumnSplitter_PointerEntered" PointerExited="AppColumnSplitter_PointerExited" Visibility="{x:Bind ViewModel.TrafficColumnVisibility, Mode=OneWay}">
                                <Rectangle Width="1" HorizontalAlignment="Center" Fill="{ThemeResource DividerStrokeColorDefaultBrush}"/>
                            </Border>

                            <TextBlock Grid.Column="6" Text="Download" Style="{StaticResource CaptionTextBlockStyle}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Visibility="{x:Bind ViewModel.TrafficColumnVisibility, Mode=OneWay}"/>
                            <Border Grid.Column="7" Tag="DownloadWidth" Style="{StaticResource AppColumnSplitterStyle}" ManipulationDelta="AppColumnSplitter_ManipulationDelta" PointerEntered="AppColumnSplitter_PointerEntered" PointerExited="AppColumnSplitter_PointerExited" Visibility="{x:Bind ViewModel.TrafficColumnVisibility, Mode=OneWay}">
                                <Rectangle Width="1" HorizontalAlignment="Center" Fill="{ThemeResource DividerStrokeColorDefaultBrush}"/>
                            </Border>

                            <TextBlock Grid.Column="8" Text="Letzte Aktivität" Style="{StaticResource CaptionTextBlockStyle}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <Border Grid.Column="9" Tag="LastSeenWidth" Style="{StaticResource AppColumnSplitterStyle}" ManipulationDelta="AppColumnSplitter_ManipulationDelta" PointerEntered="AppColumnSplitter_PointerEntered" PointerExited="AppColumnSplitter_PointerExited">
                                <Rectangle Width="1" HorizontalAlignment="Center" Fill="{ThemeResource DividerStrokeColorDefaultBrush}"/>
                            </Border>

                            <TextBlock Grid.Column="10" Text="Vertrauen" Style="{StaticResource CaptionTextBlockStyle}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <Border Grid.Column="11" Tag="TrustWidth" Style="{StaticResource AppColumnSplitterStyle}" ManipulationDelta="AppColumnSplitter_ManipulationDelta" PointerEntered="AppColumnSplitter_PointerEntered" PointerExited="AppColumnSplitter_PointerExited">
                                <Rectangle Width="1" HorizontalAlignment="Center" Fill="{ThemeResource DividerStrokeColorDefaultBrush}"/>
                            </Border>

                            <TextBlock Grid.Column="12" Text="Firewall" Style="{StaticResource CaptionTextBlockStyle}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </Grid>
                    </Border>

                    <ListView x:Name="ApplicationsList"
                              Grid.Row="1"
                              ItemsSource="{x:Bind ViewModel.Applications, Mode=OneWay}"
                              SelectionMode="Single"
                              IsItemClickEnabled="False"
                              ContextRequested="ApplicationsList_ContextRequested"
                              DoubleTapped="ApplicationsList_DoubleTapped">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="MinHeight" Value="36"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                <Setter Property="BorderBrush" Value="{ThemeResource DividerStrokeColorDefaultBrush}"/>
                            </Style>
                        </ListView.ItemContainerStyle>

                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="vm:ApplicationListItemViewModel">
                                <Grid Height="36" Margin="12,0,12,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="{Binding Layout.NameWidth, Source={StaticResource AppColumnLayout}, Mode=OneWay}"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="{Binding Layout.PathWidth, Source={StaticResource AppColumnLayout}, Mode=OneWay}"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="{Binding Layout.EffectiveUploadWidth, Source={StaticResource AppColumnLayout}, Mode=OneWay}"/>
                                        <ColumnDefinition Width="{Binding Layout.UploadSplitterWidth, Source={StaticResource AppColumnLayout}, Mode=OneWay}"/>
                                        <ColumnDefinition Width="{Binding Layout.EffectiveDownloadWidth, Source={StaticResource AppColumnLayout}, Mode=OneWay}"/>
                                        <ColumnDefinition Width="{Binding Layout.DownloadSplitterWidth, Source={StaticResource AppColumnLayout}, Mode=OneWay}"/>
                                        <ColumnDefinition Width="{Binding Layout.LastSeenWidth, Source={StaticResource AppColumnLayout}, Mode=OneWay}"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="{Binding Layout.TrustWidth, Source={StaticResource AppColumnLayout}, Mode=OneWay}"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="{Binding Layout.BlockWidth, Source={StaticResource AppColumnLayout}, Mode=OneWay}"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0"
                                               Text="{x:Bind DisplayName}"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"/>

                                    <TextBlock Grid.Column="2"
                                               Text="{x:Bind ExecutablePath}"
                                               VerticalAlignment="Center"
                                               FontFamily="Consolas"
                                               FontSize="11"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               TextTrimming="CharacterEllipsis"/>

                                    <TextBlock Grid.Column="4"
                                               Text="{x:Bind BytesSentDisplay}"
                                               VerticalAlignment="Center"
                                               FontSize="12"
                                               Visibility="{Binding ViewModel.TrafficColumnVisibility, ElementName=RootPage}"/>

                                    <TextBlock Grid.Column="6"
                                               Text="{x:Bind BytesRecvDisplay}"
                                               VerticalAlignment="Center"
                                               FontSize="12"
                                               Visibility="{Binding ViewModel.TrafficColumnVisibility, ElementName=RootPage}"/>

                                    <TextBlock Grid.Column="8"
                                               Text="{x:Bind LastSeenDisplay}"
                                               VerticalAlignment="Center"
                                               FontSize="12"/>

                                    <Border Grid.Column="10"
                                            VerticalAlignment="Center"
                                            HorizontalAlignment="Left"
                                            Background="{ThemeResource SystemFillColorSuccessBackgroundBrush}"
                                            CornerRadius="4"
                                            Padding="6,2">
                                        <TextBlock Text="{x:Bind TrustDisplay}" FontSize="10"/>
                                    </Border>

                                    <Border Grid.Column="12"
                                            VerticalAlignment="Center"
                                            HorizontalAlignment="Left"
                                            Background="{ThemeResource SystemFillColorCautionBackgroundBrush}"
                                            CornerRadius="4"
                                            Padding="6,2">
                                        <TextBlock Text="{x:Bind BlockDisplay}" FontSize="10"/>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>

                <Border x:Name="AppDetailsBackdrop"
                    Canvas.ZIndex="1"
                    Background="#80000000"
                    Opacity="0"
                    IsHitTestVisible="False"
                    Tapped="AppDetailsBackdrop_Tapped"/>

                <Border Width="520"
                        x:Name="AppDetailsPanel"
                    Canvas.ZIndex="2"
                        HorizontalAlignment="Right"
                        BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                        BorderThickness="1,0,0,0"
                        IsHitTestVisible="False">
                    <Border.Shadow>
                        <ThemeShadow/>
                    </Border.Shadow>
                    <Border.RenderTransform>
                        <TranslateTransform x:Name="AppDetailsTransform" X="520"/>
                    </Border.RenderTransform>

                    <Grid RowDefinitions="Auto,Auto,Auto,*">
                        <Border Grid.RowSpan="4"
                                Background="{ThemeResource SystemControlAcrylicWindowBrush}"
                                Opacity="0.9"/>

                        <Grid Grid.Row="0"
                              Padding="16,12,8,12"
                              BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                              BorderThickness="0,0,0,1"
                              ColumnDefinitions="*,Auto,Auto">
                            <StackPanel Grid.Column="0" Spacing="2">
                                <TextBlock Text="Anwendungsdetails"
                                           Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                                <TextBlock Text="{x:Bind ViewModel.SelectedAppName, Mode=OneWay}"
                                           Style="{ThemeResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           TextTrimming="CharacterEllipsis"/>
                            </StackPanel>

                            <Button Grid.Column="1"
                                    Style="{ThemeResource SubtleButtonStyle}"
                                    ToolTipService.ToolTip="Aktualisieren"
                                    Command="{x:Bind ViewModel.RefreshCommand}">
                                <FontIcon Glyph="&#xE72C;" FontSize="14"/>
                            </Button>

                            <Button Grid.Column="2"
                                    Style="{ThemeResource SubtleButtonStyle}"
                                    ToolTipService.ToolTip="Schließen"
                                    Command="{x:Bind ViewModel.CloseDetailsCommand}">
                                <FontIcon Glyph="&#xE711;" FontSize="14"/>
                            </Button>
                        </Grid>

                        <TextBlock Grid.Row="1"
                                   Padding="16,8,16,4"
                                   Text="{x:Bind ViewModel.SelectedAppPath, Mode=OneWay}"
                                   FontFamily="Consolas"
                                   FontSize="11"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   TextWrapping="Wrap"/>

                        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8" Padding="16,8,16,8">
                            <ToggleButton Content="Aktivität"
                                          IsChecked="{x:Bind ViewModel.IsActivitySection, Mode=OneWay}"
                                          Command="{x:Bind ViewModel.OpenActivitySectionCommand}"/>
                            <ToggleButton Content="Firewall"
                                          IsChecked="{x:Bind ViewModel.IsFirewallSection, Mode=OneWay}"
                                          Command="{x:Bind ViewModel.OpenFirewallSectionCommand}"/>
                            <ToggleButton Content="Eigenschaften"
                                          IsChecked="{x:Bind ViewModel.IsPropertiesSection, Mode=OneWay}"
                                          Command="{x:Bind ViewModel.OpenPropertiesSectionCommand}"/>
                        </StackPanel>

                        <Grid Grid.Row="3">
                            <ScrollViewer Visibility="{x:Bind ViewModel.ActivityVisibility, Mode=OneWay}">
                                <StackPanel Padding="16,8,16,16" Spacing="10">
                                    <Grid ColumnDefinitions="*,*">
                                        <Border Grid.Column="0"
                                                Background="{ThemeResource LayerFillColorAltBrush}"
                                                CornerRadius="6"
                                                Padding="10,8"
                                                Margin="0,0,6,0">
                                            <StackPanel>
                                                <TextBlock Text="Verbindungen (24h)"
                                                           Style="{ThemeResource CaptionTextBlockStyle}"/>
                                                <TextBlock Text="{x:Bind ViewModel.ConnectionCount24h, Mode=OneWay}"
                                                           FontSize="20"
                                                           FontWeight="SemiBold"/>
                                            </StackPanel>
                                        </Border>

                                        <Border Grid.Column="1"
                                                Background="{ThemeResource LayerFillColorAltBrush}"
                                                CornerRadius="6"
                                                Padding="10,8"
                                                Margin="6,0,0,0">
                                            <StackPanel>
                                                <TextBlock Text="Verdächtig (24h)"
                                                           Style="{ThemeResource CaptionTextBlockStyle}"/>
                                                <TextBlock Text="{x:Bind ViewModel.SuspiciousCount24h, Mode=OneWay}"
                                                           FontSize="20"
                                                           FontWeight="SemiBold"/>
                                            </StackPanel>
                                        </Border>
                                    </Grid>

                                    <TextBlock Text="{x:Bind ViewModel.LastActivityStatus, Mode=OneWay}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               Style="{ThemeResource CaptionTextBlockStyle}"/>

                                    <ListView ItemsSource="{x:Bind ViewModel.RecentConnections, Mode=OneWay}"
                                              SelectionMode="None">
                                        <ListView.ItemContainerStyle>
                                            <Style TargetType="ListViewItem">
                                                <Setter Property="Padding" Value="0"/>
                                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                            </Style>
                                        </ListView.ItemContainerStyle>
                                        <ListView.ItemTemplate>
                                            <DataTemplate x:DataType="vm:AppRecentConnectionViewModel">
                                                <Grid Padding="8,7"
                                                      ColumnDefinitions="110,160,60,90,*"
                                                      BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                                                      BorderThickness="0,0,0,1">
                                                    <TextBlock Grid.Column="0" Text="{x:Bind TimestampDisplay}" FontSize="11"/>
                                                    <TextBlock Grid.Column="1" Text="{x:Bind RemoteDisplay}" FontFamily="Consolas" FontSize="11"/>
                                                    <TextBlock Grid.Column="2" Text="{x:Bind Protocol}" FontSize="11"/>
                                                    <TextBlock Grid.Column="3" Text="{x:Bind BytesDisplay}" FontSize="11"/>
                                                    <TextBlock Grid.Column="4" Text="{x:Bind ReputationDisplay}" FontSize="11"/>
                                                </Grid>
                                            </DataTemplate>
                                        </ListView.ItemTemplate>
                                    </ListView>
                                </StackPanel>
                            </ScrollViewer>

                            <Grid Visibility="{x:Bind ViewModel.FirewallVisibility, Mode=OneWay}">
                                <StackPanel HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Spacing="10"
                                            Visibility="{x:Bind ViewModel.AppFirewallRules.IsLoading, Mode=OneWay}">
                                    <ProgressRing IsActive="True" Width="36" Height="36"/>
                                    <TextBlock Text="Lade Firewall-Regeln …"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                </StackPanel>

                                <StackPanel HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            MaxWidth="320"
                                            Spacing="8"
                                            Visibility="{x:Bind ViewModel.AppFirewallRules.HasNoRules, Mode=OneWay}">
                                    <TextBlock Text="Keine Firewall-Regeln"
                                               Style="{ThemeResource BodyStrongTextBlockStyle}"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Text="Für diese Anwendung sind keine spezifischen Regeln vorhanden."
                                               TextWrapping="Wrap"
                                               TextAlignment="Center"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                </StackPanel>

                                <ListView ItemsSource="{x:Bind ViewModel.AppFirewallRules.Rules, Mode=OneWay}"
                                          SelectionMode="None">
                                    <ListView.ItemContainerStyle>
                                        <Style TargetType="ListViewItem">
                                            <Setter Property="Padding" Value="0"/>
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        </Style>
                                    </ListView.ItemContainerStyle>
                                    <ListView.ItemTemplate>
                                        <DataTemplate x:DataType="vm:FirewallRuleItemViewModel">
                                            <Grid Padding="12,9"
                                                  ColumnDefinitions="20,*,Auto,Auto"
                                                  RowDefinitions="Auto,Auto"
                                                  BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                                                  BorderThickness="0,0,0,1">
                                                <FontIcon Grid.Column="0" Grid.RowSpan="2"
                                                          Glyph="{x:Bind DirectionGlyph}"
                                                          FontSize="12"
                                                          VerticalAlignment="Center"
                                                          Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                                                <TextBlock Grid.Column="1" Grid.Row="0"
                                                           Text="{x:Bind DisplayName}"
                                                           TextTrimming="CharacterEllipsis"/>

                                                <StackPanel Grid.Column="1" Grid.Row="1"
                                                            Orientation="Horizontal"
                                                            Spacing="6"
                                                            Margin="0,4,0,0">
                                                    <Border Background="{x:Bind ActionChipBackground}"
                                                            CornerRadius="4"
                                                            Padding="6,1">
                                                        <TextBlock Text="{x:Bind ActionDisplay}"
                                                                   Foreground="{x:Bind ActionChipForeground}"
                                                                   FontSize="10"
                                                                   FontWeight="SemiBold"/>
                                                    </Border>
                                                    <TextBlock Text="{x:Bind ProtocolDisplay}"
                                                               FontSize="11"
                                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                                    <TextBlock Text="{x:Bind RemoteAddressDisplay}"
                                                               FontFamily="Consolas"
                                                               FontSize="11"
                                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                                </StackPanel>

                                                <ToggleSwitch Grid.Column="2" Grid.RowSpan="2"
                                                              IsOn="{x:Bind IsEnabled, Mode=TwoWay}"
                                                              OnContent=""
                                                              OffContent=""
                                                              MinWidth="0"
                                                              VerticalAlignment="Center"/>

                                                <Button Grid.Column="3" Grid.RowSpan="2"
                                                        Style="{StaticResource SubtleButtonStyle}"
                                                        Command="{x:Bind RemoveCommand}"
                                                        ToolTipService.ToolTip="Regel entfernen">
                                                    <FontIcon Glyph="&#xE74D;" FontSize="12"/>
                                                </Button>
                                            </Grid>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </Grid>

                            <ScrollViewer Visibility="{x:Bind ViewModel.PropertiesVisibility, Mode=OneWay}">
                                <StackPanel Padding="16,8,16,16" Spacing="10">
                                    <TextBlock Text="Eigenschaften"
                                               Style="{ThemeResource BodyStrongTextBlockStyle}"/>

                                    <Grid ColumnDefinitions="140,*">
                                        <TextBlock Grid.Column="0" Text="Pfad" Style="{ThemeResource CaptionTextBlockStyle}"/>
                                        <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.SelectedAppPath, Mode=OneWay}" TextWrapping="Wrap"/>
                                    </Grid>

                                    <Grid ColumnDefinitions="140,*">
                                        <TextBlock Grid.Column="0" Text="Datei" Style="{ThemeResource CaptionTextBlockStyle}"/>
                                        <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.FileExistsDisplay, Mode=OneWay}"/>
                                    </Grid>

                                    <Grid ColumnDefinitions="140,*">
                                        <TextBlock Grid.Column="0" Text="Vertrauensstatus" Style="{ThemeResource CaptionTextBlockStyle}"/>
                                        <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.SelectedTrustDisplay, Mode=OneWay}"/>
                                    </Grid>

                                    <Grid ColumnDefinitions="140,*">
                                        <TextBlock Grid.Column="0" Text="Firewallstatus" Style="{ThemeResource CaptionTextBlockStyle}"/>
                                        <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.SelectedBlockDisplay, Mode=OneWay}"/>
                                    </Grid>

                                    <Grid ColumnDefinitions="140,*">
                                        <TextBlock Grid.Column="0" Text="Letzte Sichtung" Style="{ThemeResource CaptionTextBlockStyle}"/>
                                        <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.SelectedLastSeenDisplay, Mode=OneWay}"/>
                                    </Grid>

                                    <Grid ColumnDefinitions="140,*">
                                        <TextBlock Grid.Column="0" Text="Traffic gesamt" Style="{ThemeResource CaptionTextBlockStyle}"/>
                                        <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.SelectedTrafficDisplay, Mode=OneWay}"/>
                                    </Grid>
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Page>
