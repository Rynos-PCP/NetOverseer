<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="NetOverseer.App.Views.DnsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:NetOverseer.App.ViewModels">

    <Page.Resources>
        <!-- Singleton-Layout der Spaltenbreiten – Header und Zeilen binden an dieselbe Instanz. -->
        <vm:DnsColumnLayoutSource x:Key="DnsColumnLayout"/>

        <!-- 8 px breiter Splitter (Border + ManipulationDelta). -->
        <Style x:Key="DnsColumnSplitterStyle" TargetType="Border">
            <Setter Property="Width" Value="8"/>
            <Setter Property="VerticalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="ManipulationMode" Value="TranslateX"/>
        </Style>
    </Page.Resources>

    <Grid RowDefinitions="Auto,Auto,Auto,Auto,*">

        <!-- ════ Warn-Banner ════ -->
        <InfoBar
            Grid.Row="0"
            IsOpen="{x:Bind ViewModel.ShowStatusBanner, Mode=OneWay}"
            IsClosable="False"
            Severity="Warning"
            Title="DNS-Überwachung inaktiv"
            Message="{x:Bind ViewModel.StatusText, Mode=OneWay}">
            <InfoBar.ActionButton>
                <Button Content="Erneut starten"
                        Command="{x:Bind ViewModel.RestartCaptureCommand}"/>
            </InfoBar.ActionButton>
        </InfoBar>

        <!-- ════ Statistik-Karten ════ -->
        <Grid Grid.Row="1" Padding="16,12,16,8"
              ColumnDefinitions="*,*,*,*,*,Auto"
              ColumnSpacing="8">

            <Border Grid.Column="0"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="6" Padding="12,8">
                <StackPanel Spacing="2">
                    <TextBlock Text="Gesamt"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <TextBlock Text="{x:Bind ViewModel.TotalCount, Mode=OneWay}"
                               Style="{StaticResource SubtitleTextBlockStyle}"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="1"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="6" Padding="12,8">
                <StackPanel Spacing="2">
                    <TextBlock Text="Tracker"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="#FFC8641E"/>
                    <TextBlock Text="{x:Bind ViewModel.TrackerCount, Mode=OneWay}"
                               Style="{StaticResource SubtitleTextBlockStyle}"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="2"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="6" Padding="12,8">
                <StackPanel Spacing="2">
                    <TextBlock Text="Telemetrie"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="#FF3264C8"/>
                    <TextBlock Text="{x:Bind ViewModel.TelemetryCount, Mode=OneWay}"
                               Style="{StaticResource SubtitleTextBlockStyle}"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="3"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="6" Padding="12,8">
                <StackPanel Spacing="2">
                    <TextBlock Text="CDN"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <TextBlock Text="{x:Bind ViewModel.CdnCount, Mode=OneWay}"
                               Style="{StaticResource SubtitleTextBlockStyle}"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="4"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="#FFC83232"
                    BorderThickness="1" CornerRadius="6" Padding="12,8"
                    Visibility="{x:Bind ViewModel.SuspiciousCountVisibility, Mode=OneWay}">
                <StackPanel Spacing="2">
                    <TextBlock Text="Verdächtig"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="#FFC83232"/>
                    <TextBlock Text="{x:Bind ViewModel.SuspiciousCount, Mode=OneWay}"
                               Style="{StaticResource SubtitleTextBlockStyle}"
                               Foreground="#FFC83232"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="5"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="6" Padding="12,8"
                    MinWidth="110">
                <StackPanel Spacing="2">
                    <TextBlock Text="Rate (Roh)"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <TextBlock Text="{x:Bind ViewModel.RatePerSecond, Mode=OneWay}"
                                   Style="{StaticResource SubtitleTextBlockStyle}"/>
                        <TextBlock Text="/s"
                                   VerticalAlignment="Bottom"
                                   Margin="0,0,0,4"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ════ Diagnose-Zeile ════ -->
        <Grid Grid.Row="2" Padding="16,0,16,8"
              ColumnDefinitions="*,Auto">
            <StackPanel Grid.Column="0"
                        Orientation="Horizontal"
                        Spacing="16"
                        VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                    <TextBlock Text="●" FontSize="14"
                               Foreground="{x:Bind ViewModel.CaptureStateColor, Mode=OneWay}"/>
                    <TextBlock Text="{x:Bind ViewModel.CaptureStateText, Mode=OneWay}"
                               FontWeight="SemiBold" FontSize="12"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <TextBlock VerticalAlignment="Center" FontSize="12"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                    <Run Text="ETW-Roh:"/>
                    <Run Text="{x:Bind ViewModel.EventsReceived, Mode=OneWay}" FontWeight="SemiBold"/>
                    <Run Text="  •  Akzeptiert:"/>
                    <Run Text="{x:Bind ViewModel.EventsAccepted, Mode=OneWay}" FontWeight="SemiBold"/>
                    <Run Text="  •  Laufzeit:"/>
                    <Run Text="{x:Bind ViewModel.RuntimeText, Mode=OneWay}" FontWeight="SemiBold"/>
                </TextBlock>

                <TextBlock Text="{x:Bind ViewModel.SelfTestText, Mode=OneWay}"
                           VerticalAlignment="Center" FontSize="12"
                           Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                           TextTrimming="CharacterEllipsis"
                           MaxWidth="500"/>
            </StackPanel>

            <StackPanel Grid.Column="1"
                        Orientation="Horizontal" Spacing="8"
                        VerticalAlignment="Center">
                <Button Content="Self-Test"
                        Command="{x:Bind ViewModel.RunSelfTestCommand}"
                        ToolTipService.ToolTip="Führt eine Test-DNS-Anfrage aus und prüft, ob sie in der Pipeline ankommt."/>
                <Button Content="Neu starten"
                        Command="{x:Bind ViewModel.RestartCaptureCommand}"/>
                <Button Content="Leeren"
                        Command="{x:Bind ViewModel.ClearCommand}"/>
            </StackPanel>
        </Grid>

        <!-- ════ Filter-Leiste ════ -->
        <Grid Grid.Row="3" Padding="16,4,16,8"
              ColumnDefinitions="*,Auto">
            <TextBox
                Grid.Column="0"
                PlaceholderText="Domain oder Prozess filtern …"
                Text="{x:Bind ViewModel.FilterText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                MaxWidth="500"
                HorizontalAlignment="Stretch"/>

            <ComboBox
                Grid.Column="1"
                Margin="8,0,0,0"
                MinWidth="140"
                ItemsSource="{x:Bind ViewModel.CategoryOptions}"
                SelectedItem="{x:Bind ViewModel.SelectedCategory, Mode=TwoWay}"/>
        </Grid>

        <!-- ════ DNS-Tabelle ════ -->
        <Grid Grid.Row="4" RowDefinitions="Auto,*">

            <Grid Grid.Row="0"
                  Padding="16,6"
                  Background="{ThemeResource LayerFillColorAltBrush}"
                  BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                  BorderThickness="0,0,0,1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="{Binding Layout.TimeWidth,     Source={StaticResource DnsColumnLayout}, Mode=OneWay}"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="{Binding Layout.ProcessWidth,  Source={StaticResource DnsColumnLayout}, Mode=OneWay}"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="{Binding Layout.DomainWidth,   Source={StaticResource DnsColumnLayout}, Mode=OneWay}"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="{Binding Layout.TypeWidth,     Source={StaticResource DnsColumnLayout}, Mode=OneWay}"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="{Binding Layout.CategoryWidth, Source={StaticResource DnsColumnLayout}, Mode=OneWay}"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="ZEIT"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           VerticalAlignment="Center"/>
                <Border Grid.Column="1" Tag="TimeWidth"
                        Style="{StaticResource DnsColumnSplitterStyle}"
                        ManipulationDelta="ColumnSplitter_ManipulationDelta"
                        PointerEntered="ColumnSplitter_PointerEntered"
                        PointerExited="ColumnSplitter_PointerExited">
                    <Rectangle Width="1" HorizontalAlignment="Center"
                               Fill="{ThemeResource DividerStrokeColorDefaultBrush}"/>
                </Border>

                <TextBlock Grid.Column="2" Text="PROZESS"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           VerticalAlignment="Center"/>
                <Border Grid.Column="3" Tag="ProcessWidth"
                        Style="{StaticResource DnsColumnSplitterStyle}"
                        ManipulationDelta="ColumnSplitter_ManipulationDelta"
                        PointerEntered="ColumnSplitter_PointerEntered"
                        PointerExited="ColumnSplitter_PointerExited">
                    <Rectangle Width="1" HorizontalAlignment="Center"
                               Fill="{ThemeResource DividerStrokeColorDefaultBrush}"/>
                </Border>

                <TextBlock Grid.Column="4" Text="DOMAIN"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           VerticalAlignment="Center"/>
                <Border Grid.Column="5" Tag="DomainWidth"
                        Style="{StaticResource DnsColumnSplitterStyle}"
                        ManipulationDelta="ColumnSplitter_ManipulationDelta"
                        PointerEntered="ColumnSplitter_PointerEntered"
                        PointerExited="ColumnSplitter_PointerExited">
                    <Rectangle Width="1" HorizontalAlignment="Center"
                               Fill="{ThemeResource DividerStrokeColorDefaultBrush}"/>
                </Border>

                <TextBlock Grid.Column="6" Text="TYP"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           VerticalAlignment="Center"/>
                <Border Grid.Column="7" Tag="TypeWidth"
                        Style="{StaticResource DnsColumnSplitterStyle}"
                        ManipulationDelta="ColumnSplitter_ManipulationDelta"
                        PointerEntered="ColumnSplitter_PointerEntered"
                        PointerExited="ColumnSplitter_PointerExited">
                    <Rectangle Width="1" HorizontalAlignment="Center"
                               Fill="{ThemeResource DividerStrokeColorDefaultBrush}"/>
                </Border>

                <TextBlock Grid.Column="8" Text="KATEGORIE"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           VerticalAlignment="Center"/>
                <Border Grid.Column="9" Tag="CategoryWidth"
                        Style="{StaticResource DnsColumnSplitterStyle}"
                        ManipulationDelta="ColumnSplitter_ManipulationDelta"
                        PointerEntered="ColumnSplitter_PointerEntered"
                        PointerExited="ColumnSplitter_PointerExited">
                    <Rectangle Width="1" HorizontalAlignment="Center"
                               Fill="{ThemeResource DividerStrokeColorDefaultBrush}"/>
                </Border>

                <TextBlock Grid.Column="10" Text="AUFGELÖSTE IPS"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           VerticalAlignment="Center"/>
            </Grid>

            <ListView
                Grid.Row="1"
                x:Name="QueriesListView"
                ItemsSource="{x:Bind ViewModel.Queries, Mode=OneWay}"
                SelectionMode="Single"
                ScrollViewer.HorizontalScrollMode="Disabled"
                ScrollViewer.HorizontalScrollBarVisibility="Disabled">

                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="MinHeight" Value="34"/>
                    </Style>
                </ListView.ItemContainerStyle>

                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="vm:DnsQueryItemViewModel">
                        <Grid
                            Background="{x:Bind RowBackground}"
                            Padding="16,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="{Binding Layout.TimeWidth,     Source={StaticResource DnsColumnLayout}, Mode=OneWay}"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="{Binding Layout.ProcessWidth,  Source={StaticResource DnsColumnLayout}, Mode=OneWay}"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="{Binding Layout.DomainWidth,   Source={StaticResource DnsColumnLayout}, Mode=OneWay}"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="{Binding Layout.TypeWidth,     Source={StaticResource DnsColumnLayout}, Mode=OneWay}"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="{Binding Layout.CategoryWidth, Source={StaticResource DnsColumnLayout}, Mode=OneWay}"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Text="{x:Bind TimeDisplay}"
                                       FontFamily="Cascadia Mono, Consolas"
                                       FontSize="11"
                                       VerticalAlignment="Center"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                            <TextBlock Grid.Column="2"
                                       Text="{x:Bind ProcessDisplay}"
                                       FontSize="12"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"
                                       ToolTipService.ToolTip="{x:Bind ProcessDisplay}"/>

                            <TextBlock Grid.Column="4"
                                       Text="{x:Bind QueryName}"
                                       FontSize="12"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"
                                       ToolTipService.ToolTip="{x:Bind QueryName}"/>

                            <TextBlock Grid.Column="6"
                                       Text="{x:Bind QueryTypeDisplay}"
                                       FontSize="11"
                                       VerticalAlignment="Center"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                            <Border Grid.Column="8"
                                    Background="{x:Bind CategoryBackground}"
                                    CornerRadius="4"
                                    Padding="6,2"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center">
                                <TextBlock Text="{x:Bind CategoryDisplay}"
                                           Foreground="{x:Bind CategoryForeground}"
                                           FontSize="11"/>
                            </Border>

                            <TextBlock Grid.Column="10"
                                       Text="{x:Bind ResolvedIpsDisplay}"
                                       FontFamily="Cascadia Mono, Consolas"
                                       FontSize="11"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"
                                       ToolTipService.ToolTip="{x:Bind ResolvedIpsDisplay}"/>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>
    </Grid>
</Page>
