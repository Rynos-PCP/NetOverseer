<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="NetOverseer.App.Views.StartupPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:NetOverseer.App.ViewModels">

    <Page.Resources>
        <!-- Singleton-Layout fÃ¼r Spaltenbreiten â€“ Header und Zeilen-Template binden
             an dieselbe Instanz, damit Drag-Resize auf alle Zeilen wirkt. -->
        <vm:StartupColumnLayoutSource x:Key="StartupColumnLayout"/>

        <!-- 8 px breiter Splitter (Border + ManipulationDelta) mit zentrierter Trennlinie. -->
        <Style x:Key="StartupColumnSplitterStyle" TargetType="Border">
            <Setter Property="Width" Value="8"/>
            <Setter Property="VerticalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="ManipulationMode" Value="TranslateX"/>
        </Style>
    </Page.Resources>

    <Grid RowDefinitions="Auto,Auto,Auto,Auto,*">

        <!-- â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
             Zeile 0 â€“ Lade-Indikator
             â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• -->
        <ProgressBar
            Grid.Row="0"
            IsIndeterminate="True"
            Visibility="{x:Bind ViewModel.LoadingVisibility, Mode=OneWay}"/>

        <!-- â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
             Zeile 1 â€“ Autostart-Steuerung (NEU)
             â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• -->
        <Border
            Grid.Row="1"
            Margin="16,12,16,0"
            Padding="16,12"
            CornerRadius="8"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1">
            <StackPanel Spacing="10">
                <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                    <StackPanel Grid.Column="0" Spacing="2">
                        <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                            <TextBlock
                                Text="Bootmonitor (Pre-Login)"
                                Style="{StaticResource BodyStrongTextBlockStyle}"/>
                            <Border
                                CornerRadius="10"
                                Padding="8,2"
                                Background="{x:Bind ViewModel.StatusBadgeBrush, Mode=OneWay}">
                                <TextBlock
                                    Text="{x:Bind ViewModel.StatusBadgeText, Mode=OneWay}"
                                    FontSize="11"
                                    FontWeight="SemiBold"
                                    Foreground="White"/>
                            </Border>
                        </StackPanel>
                        <TextBlock
                            Text="LÃ¤uft als SYSTEM bereits beim Windows-Start â€“ noch vor der Benutzeranmeldung â€“ und zeichnet die ersten 60 Sekunden Netzwerkverbindungen auf."
                            Style="{StaticResource CaptionTextBlockStyle}"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            TextWrapping="Wrap"
                            MaxWidth="700"/>
                    </StackPanel>

                    <StackPanel
                        Grid.Column="1"
                        Orientation="Horizontal"
                        Spacing="8"
                        VerticalAlignment="Center">
                        <Button
                            Content="Aktivieren"
                            Style="{StaticResource AccentButtonStyle}"
                            Command="{x:Bind ViewModel.InstallAutostartCommand}"
                            IsEnabled="{x:Bind ViewModel.CanInstall, Mode=OneWay}"/>
                        <Button
                            Content="Deaktivieren"
                            Command="{x:Bind ViewModel.UninstallAutostartCommand}"
                            IsEnabled="{x:Bind ViewModel.IsAutostartInstalled, Mode=OneWay}"/>
                        <Button
                            Content="Jetzt testen"
                            Command="{x:Bind ViewModel.RunNowCommand}"
                            ToolTipService.ToolTip="Startet eine 60-Sekunden-Testaufzeichnung im aktuellen Prozess (ohne Neustart)."/>
                        <Button
                            Command="{x:Bind ViewModel.RefreshCommand}"
                            ToolTipService.ToolTip="Letzte Aufzeichnung neu laden">
                            <FontIcon Glyph="&#xE72C;" FontSize="14"/>
                        </Button>
                    </StackPanel>
                </Grid>

                <InfoBar
                    IsOpen="{x:Bind ViewModel.HasStatusMessage, Mode=OneWay}"
                    Message="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                    IsClosable="True"
                    Severity="Informational"/>
            </StackPanel>
        </Border>

        <!-- â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
             Zeile 2 â€“ Session-Zusammenfassung
             â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• -->
        <Border
            Grid.Row="2"
            Margin="16,8,16,0"
            Padding="16,10"
            CornerRadius="8"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            Visibility="{x:Bind ViewModel.HasDataVisibility, Mode=OneWay}">

            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Orientation="Horizontal" Spacing="24" VerticalAlignment="Center">
                    <!-- Systemstart -->
                    <StackPanel>
                        <TextBlock
                            Text="Letzter Systemstart"
                            Style="{StaticResource CaptionTextBlockStyle}"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <TextBlock
                            Text="{x:Bind ViewModel.SessionBootText, Mode=OneWay}"
                            Style="{StaticResource BodyStrongTextBlockStyle}"/>
                    </StackPanel>

                    <!-- Aufzeichnungsdauer -->
                    <StackPanel>
                        <TextBlock
                            Text="Aufzeichnung"
                            Style="{StaticResource CaptionTextBlockStyle}"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <TextBlock
                            Text="{x:Bind ViewModel.SessionDurationText, Mode=OneWay}"
                            Style="{StaticResource BodyStrongTextBlockStyle}"/>
                    </StackPanel>

                    <!-- Verbindungsanzahl -->
                    <StackPanel>
                        <TextBlock
                            Text="Verbindungen"
                            Style="{StaticResource CaptionTextBlockStyle}"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <TextBlock
                            Text="{x:Bind ViewModel.SessionConnectionText, Mode=OneWay}"
                            Style="{StaticResource BodyStrongTextBlockStyle}"/>
                    </StackPanel>

                    <!-- Prozesse -->
                    <StackPanel>
                        <TextBlock
                            Text="Prozesse"
                            Style="{StaticResource CaptionTextBlockStyle}"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <TextBlock
                            Text="{x:Bind ViewModel.ProcessGroups.Count, Mode=OneWay}"
                            Style="{StaticResource BodyStrongTextBlockStyle}"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
             Zeile 4 â€“ Hauptinhalt (resizable Tabelle, einheitlicher Stil)
             â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• -->
        <Grid Grid.Row="4" Margin="16,8,16,16">
            <Grid.RowDefinitions>
                <RowDefinition Height="36"/>  <!-- Spalten-Kopfzeile -->
                <RowDefinition Height="*"/>   <!-- Liste / Leer-Zustand -->
            </Grid.RowDefinitions>

            <!-- â”€â”€ Leer-Zustand â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ -->
            <StackPanel
                Grid.Row="1"
                Spacing="12"
                Padding="0,60,0,0"
                HorizontalAlignment="Center"
                Visibility="{x:Bind ViewModel.NoDataVisibility, Mode=OneWay}">
                <FontIcon
                    Glyph="&#xE7E8;"
                    FontSize="56"
                    Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                    HorizontalAlignment="Center"/>
                <TextBlock
                    Text="Noch keine Aufzeichnung vorhanden"
                    Style="{StaticResource SubtitleTextBlockStyle}"
                    HorizontalAlignment="Center"/>
                <TextBlock
                    Text="Klicke oben auf â€žAktivierenâ€œ, um den Bootmonitor einzurichten. Beim nÃ¤chsten Windows-Start werden die ersten 60 Sekunden Netzwerkverbindungen als SYSTEM aufgezeichnet â€“ noch vor der Anmeldung."
                    Style="{StaticResource BodyTextBlockStyle}"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    TextWrapping="WrapWholeWords"
                    MaxWidth="480"
                    HorizontalAlignment="Center"
                    TextAlignment="Center"/>
            </StackPanel>

            <!-- â”€â”€ Spalten-Kopfzeile (resizable) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ -->
            <Border
                Grid.Row="0"
                Background="{ThemeResource SystemControlBackgroundChromeMediumBrush}"
                BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                BorderThickness="0,0,0,1"
                Visibility="{x:Bind ViewModel.HasDataVisibility, Mode=OneWay}">

                <Grid Margin="12,0,12,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="{Binding Layout.OffsetWidth,   Source={StaticResource StartupColumnLayout}, Mode=OneWay}"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="{Binding Layout.ProcessWidth,  Source={StaticResource StartupColumnLayout}, Mode=OneWay}"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="{Binding Layout.PidWidth,      Source={StaticResource StartupColumnLayout}, Mode=OneWay}"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="{Binding Layout.ProtocolWidth, Source={StaticResource StartupColumnLayout}, Mode=OneWay}"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="{Binding Layout.LocalWidth,    Source={StaticResource StartupColumnLayout}, Mode=OneWay}"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="{Binding Layout.RemoteWidth,   Source={StaticResource StartupColumnLayout}, Mode=OneWay}"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"  Text="Zeit"      Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                    <Border Grid.Column="1"  Tag="OffsetWidth"   Style="{StaticResource StartupColumnSplitterStyle}" ManipulationDelta="ColumnSplitter_ManipulationDelta" PointerEntered="ColumnSplitter_PointerEntered" PointerExited="ColumnSplitter_PointerExited">
                        <Rectangle Width="1" HorizontalAlignment="Center" Fill="{ThemeResource DividerStrokeColorDefaultBrush}"/>
                    </Border>

                    <TextBlock Grid.Column="2"  Text="Prozess"   Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                    <Border Grid.Column="3"  Tag="ProcessWidth"  Style="{StaticResource StartupColumnSplitterStyle}" ManipulationDelta="ColumnSplitter_ManipulationDelta" PointerEntered="ColumnSplitter_PointerEntered" PointerExited="ColumnSplitter_PointerExited">
                        <Rectangle Width="1" HorizontalAlignment="Center" Fill="{ThemeResource DividerStrokeColorDefaultBrush}"/>
                    </Border>

                    <TextBlock Grid.Column="4"  Text="PID"       Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                    <Border Grid.Column="5"  Tag="PidWidth"      Style="{StaticResource StartupColumnSplitterStyle}" ManipulationDelta="ColumnSplitter_ManipulationDelta" PointerEntered="ColumnSplitter_PointerEntered" PointerExited="ColumnSplitter_PointerExited">
                        <Rectangle Width="1" HorizontalAlignment="Center" Fill="{ThemeResource DividerStrokeColorDefaultBrush}"/>
                    </Border>

                    <TextBlock Grid.Column="6"  Text="Proto"     Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                    <Border Grid.Column="7"  Tag="ProtocolWidth" Style="{StaticResource StartupColumnSplitterStyle}" ManipulationDelta="ColumnSplitter_ManipulationDelta" PointerEntered="ColumnSplitter_PointerEntered" PointerExited="ColumnSplitter_PointerExited">
                        <Rectangle Width="1" HorizontalAlignment="Center" Fill="{ThemeResource DividerStrokeColorDefaultBrush}"/>
                    </Border>

                    <TextBlock Grid.Column="8"  Text="Lokal"     Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                    <Border Grid.Column="9"  Tag="LocalWidth"    Style="{StaticResource StartupColumnSplitterStyle}" ManipulationDelta="ColumnSplitter_ManipulationDelta" PointerEntered="ColumnSplitter_PointerEntered" PointerExited="ColumnSplitter_PointerExited">
                        <Rectangle Width="1" HorizontalAlignment="Center" Fill="{ThemeResource DividerStrokeColorDefaultBrush}"/>
                    </Border>

                    <TextBlock Grid.Column="10" Text="Remote"    Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                    <Border Grid.Column="11" Tag="RemoteWidth"   Style="{StaticResource StartupColumnSplitterStyle}" ManipulationDelta="ColumnSplitter_ManipulationDelta" PointerEntered="ColumnSplitter_PointerEntered" PointerExited="ColumnSplitter_PointerExited">
                        <Rectangle Width="1" HorizontalAlignment="Center" Fill="{ThemeResource DividerStrokeColorDefaultBrush}"/>
                    </Border>
                </Grid>
            </Border>

            <!-- â”€â”€ Verbindungsliste â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ -->
            <ListView
                Grid.Row="1"
                x:Name="ConnectionList"
                ItemsSource="{x:Bind ViewModel.Connections, Mode=OneWay}"
                SelectionMode="Single"
                IsItemClickEnabled="False"
                ContextRequested="ConnectionList_ContextRequested"
                Visibility="{x:Bind ViewModel.HasDataVisibility, Mode=OneWay}">

                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="MinHeight" Value="34"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        <Setter Property="BorderBrush" Value="{ThemeResource DividerStrokeColorDefaultBrush}"/>
                    </Style>
                </ListView.ItemContainerStyle>

                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="vm:StartupConnectionItemViewModel">
                        <Grid Margin="12,0,12,0" Height="32">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="{Binding Layout.OffsetWidth,   Source={StaticResource StartupColumnLayout}, Mode=OneWay}"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="{Binding Layout.ProcessWidth,  Source={StaticResource StartupColumnLayout}, Mode=OneWay}"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="{Binding Layout.PidWidth,      Source={StaticResource StartupColumnLayout}, Mode=OneWay}"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="{Binding Layout.ProtocolWidth, Source={StaticResource StartupColumnLayout}, Mode=OneWay}"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="{Binding Layout.LocalWidth,    Source={StaticResource StartupColumnLayout}, Mode=OneWay}"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="{Binding Layout.RemoteWidth,   Source={StaticResource StartupColumnLayout}, Mode=OneWay}"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Text="{x:Bind OffsetText}"
                                       VerticalAlignment="Center"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="{ThemeResource SystemAccentColor}"
                                       TextTrimming="CharacterEllipsis"/>

                            <TextBlock Grid.Column="2"
                                       Text="{x:Bind ProcessName}"
                                       VerticalAlignment="Center"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       TextTrimming="CharacterEllipsis"/>

                            <TextBlock Grid.Column="4"
                                       Text="{x:Bind ProcessId}"
                                       VerticalAlignment="Center"
                                       FontSize="11"
                                       Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                       TextTrimming="CharacterEllipsis"/>

                            <TextBlock Grid.Column="6"
                                       Text="{x:Bind Protocol}"
                                       VerticalAlignment="Center"
                                       FontSize="12"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                            <TextBlock Grid.Column="8"
                                       Text="{x:Bind LocalDisplay}"
                                       VerticalAlignment="Center"
                                       FontFamily="Cascadia Code,Consolas,Courier New"
                                       FontSize="11"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       TextTrimming="CharacterEllipsis"/>

                            <TextBlock Grid.Column="10"
                                       Text="{x:Bind RemoteDisplay}"
                                       VerticalAlignment="Center"
                                       FontFamily="Cascadia Code,Consolas,Courier New"
                                       FontSize="11"
                                       TextTrimming="CharacterEllipsis"/>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>
    </Grid>
</Page>
