<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="NetOverseer.App.Views.TelemetryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:NetOverseer.App.ViewModels"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls">

    <Page.Resources>
        <!-- Singleton-Layout für Spaltenbreiten (Header und Zeilen-Template binden
             gegen dieselbe Instanz) -->
        <vm:TelemetryColumnLayoutSource x:Key="TelemetryColumnLayout"/>

        <!-- 8 px breiter, unsichtbarer Splitter (Border + ManipulationDelta) -->
        <Style x:Key="TelemetryColumnSplitterStyle" TargetType="Border">
            <Setter Property="Width" Value="8"/>
            <Setter Property="VerticalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="ManipulationMode" Value="TranslateX"/>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Statistik-Karten + Aktionen -->
            <RowDefinition Height="Auto"/>   <!-- Service-Chips (Filter) -->
            <RowDefinition Height="Auto"/>   <!-- Spalten-Header -->
            <RowDefinition Height="*"/>      <!-- Tabelle / Leer-Zustand -->
            <RowDefinition Height="Auto"/>   <!-- Status-Leiste -->
        </Grid.RowDefinitions>

        <!-- ═════════════════════════════════════════════════════════════
             Statistik-Karten + Such- und Aktionsleiste
             ═════════════════════════════════════════════════════════════ -->
        <Border
            Grid.Row="0"
            Padding="16,12"
            Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}"
            BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
            BorderThickness="0,0,0,1">

            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Karte: Verbindungen -->
                <Border Grid.Column="0" CornerRadius="8" Padding="16,10"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="{x:Bind ViewModel.TotalConnectionCount, Mode=OneWay}"
                                   FontSize="22" FontWeight="SemiBold"
                                   Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                        <TextBlock Text="Verbindungen" FontSize="11"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                </Border>

                <!-- Karte: Eindeutige Hosts -->
                <Border Grid.Column="1" CornerRadius="8" Padding="16,10"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="{x:Bind ViewModel.UniqueHostCount, Mode=OneWay}"
                                   FontSize="22" FontWeight="SemiBold"
                                   Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                        <TextBlock Text="Eindeutige Hosts" FontSize="11"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                </Border>

                <!-- Karte: Aktive Dienste -->
                <Border Grid.Column="2" CornerRadius="8" Padding="16,10"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="{x:Bind ViewModel.ActiveServiceCount, Mode=OneWay}"
                                   FontSize="22" FontWeight="SemiBold"
                                   Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                        <TextBlock Text="Aktive Dienste" FontSize="11"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                </Border>

                <!-- Karte: Übertragen -->
                <Border Grid.Column="3" CornerRadius="8" Padding="16,10"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="{x:Bind ViewModel.TotalBytesDisplay, Mode=OneWay}"
                                   FontSize="22" FontWeight="SemiBold"
                                   Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                        <TextBlock Text="Übertragen" FontSize="11"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                </Border>

                <!-- Suchfeld -->
                <AutoSuggestBox
                    Grid.Column="5"
                    Width="260"
                    PlaceholderText="Hostname, IP oder Prozess filtern …"
                    QueryIcon="Find"
                    Text="{x:Bind ViewModel.SearchText, Mode=TwoWay}"
                    VerticalAlignment="Center"/>

                <!-- Export HTML -->
                <Button
                    Grid.Column="6"
                    VerticalAlignment="Center"
                    Command="{x:Bind ViewModel.ExportReportCommand}"
                    ToolTipService.ToolTip="HTML-Bericht in 'Downloads' speichern und öffnen">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE74E;" FontSize="14"/>
                        <TextBlock Text="HTML-Bericht"/>
                    </StackPanel>
                </Button>

                <!-- Löschen -->
                <Button
                    Grid.Column="7"
                    VerticalAlignment="Center"
                    Command="{x:Bind ViewModel.ClearDataCommand}"
                    ToolTipService.ToolTip="Erfasste Daten zurücksetzen">
                    <FontIcon Glyph="&#xE74D;" FontSize="14"/>
                </Button>
            </Grid>
        </Border>

        <!-- ═════════════════════════════════════════════════════════════
             Dienst-Chips (klickbarer Filter)
             ═════════════════════════════════════════════════════════════ -->
        <Border
            Grid.Row="1"
            Padding="16,8"
            Background="{ThemeResource LayerFillColorDefaultBrush}"
            BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
            BorderThickness="0,0,0,1"
            Visibility="{x:Bind ViewModel.ContentVisibility, Mode=OneWay}">

            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Disabled"
                          HorizontalScrollMode="Auto">
                <StackPanel Orientation="Horizontal" Spacing="6">

                    <!-- "Alle" Chip -->
                    <Button
                        Click="ClearFilter_Click"
                        Padding="10,4"
                        MinWidth="0" MinHeight="0"
                        Background="{ThemeResource ControlFillColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="12">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <FontIcon Glyph="&#xE71C;" FontSize="11"/>
                            <TextBlock Text="Alle" FontSize="12"/>
                        </StackPanel>
                    </Button>

                    <!-- Service-Chips dynamisch -->
                    <ItemsControl ItemsSource="{x:Bind ViewModel.Services, Mode=OneWay}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" Spacing="6"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:TelemetryServiceChipViewModel">
                                <Button
                                    Click="ServiceChip_Click"
                                    Tag="{x:Bind ServiceName}"
                                    Padding="10,4"
                                    MinWidth="0" MinHeight="0"
                                    CornerRadius="12"
                                    BorderThickness="1">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <Border Width="8" Height="8" CornerRadius="4"
                                                Background="{x:Bind Brush}"
                                                VerticalAlignment="Center"/>
                                        <TextBlock Text="{x:Bind ServiceName}" FontSize="12"
                                                   VerticalAlignment="Center"/>
                                        <Border Background="{ThemeResource SubtleFillColorTertiaryBrush}"
                                                CornerRadius="8" Padding="6,0">
                                            <TextBlock Text="{x:Bind HitCount, Mode=OneWay}" FontSize="11"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        </Border>
                                    </StackPanel>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- ═════════════════════════════════════════════════════════════
             Spalten-Header
             ═════════════════════════════════════════════════════════════ -->
        <Border
            Grid.Row="2"
            Background="{ThemeResource LayerFillColorDefaultBrush}"
            BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
            BorderThickness="0,0,0,1"
            Padding="12,0"
            Visibility="{x:Bind ViewModel.ContentVisibility, Mode=OneWay}">

            <Grid Height="32">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="{Binding Layout.ServiceWidth,  Source={StaticResource TelemetryColumnLayout}, Mode=OneWay}"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="{Binding Layout.HostnameWidth, Source={StaticResource TelemetryColumnLayout}, Mode=OneWay}"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="{Binding Layout.ProcessWidth,  Source={StaticResource TelemetryColumnLayout}, Mode=OneWay}"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="{Binding Layout.PidWidth,      Source={StaticResource TelemetryColumnLayout}, Mode=OneWay}"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="{Binding Layout.RemoteIpWidth, Source={StaticResource TelemetryColumnLayout}, Mode=OneWay}"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="{Binding Layout.CountryWidth,  Source={StaticResource TelemetryColumnLayout}, Mode=OneWay}"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="{Binding Layout.HitsWidth,     Source={StaticResource TelemetryColumnLayout}, Mode=OneWay}"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="{Binding Layout.BytesWidth,    Source={StaticResource TelemetryColumnLayout}, Mode=OneWay}"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="{Binding Layout.LastSeenWidth, Source={StaticResource TelemetryColumnLayout}, Mode=OneWay}"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"  Text="Dienst"    VerticalAlignment="Center" FontWeight="SemiBold" FontSize="11"/>
                <Border    Grid.Column="1"  Tag="ServiceWidth"  Style="{StaticResource TelemetryColumnSplitterStyle}" ManipulationDelta="ColumnSplitter_ManipulationDelta" PointerEntered="ColumnSplitter_PointerEntered" PointerExited="ColumnSplitter_PointerExited">
                    <Rectangle Width="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}"/>
                </Border>
                <TextBlock Grid.Column="2"  Text="Hostname"  VerticalAlignment="Center" FontWeight="SemiBold" FontSize="11"/>
                <Border    Grid.Column="3"  Tag="HostnameWidth" Style="{StaticResource TelemetryColumnSplitterStyle}" ManipulationDelta="ColumnSplitter_ManipulationDelta" PointerEntered="ColumnSplitter_PointerEntered" PointerExited="ColumnSplitter_PointerExited">
                    <Rectangle Width="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}"/>
                </Border>
                <TextBlock Grid.Column="4"  Text="Prozess"   VerticalAlignment="Center" FontWeight="SemiBold" FontSize="11"/>
                <Border    Grid.Column="5"  Tag="ProcessWidth" Style="{StaticResource TelemetryColumnSplitterStyle}" ManipulationDelta="ColumnSplitter_ManipulationDelta" PointerEntered="ColumnSplitter_PointerEntered" PointerExited="ColumnSplitter_PointerExited">
                    <Rectangle Width="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}"/>
                </Border>
                <TextBlock Grid.Column="6"  Text="PID"       VerticalAlignment="Center" FontWeight="SemiBold" FontSize="11"/>
                <Border    Grid.Column="7"  Tag="PidWidth"    Style="{StaticResource TelemetryColumnSplitterStyle}" ManipulationDelta="ColumnSplitter_ManipulationDelta" PointerEntered="ColumnSplitter_PointerEntered" PointerExited="ColumnSplitter_PointerExited">
                    <Rectangle Width="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}"/>
                </Border>
                <TextBlock Grid.Column="8"  Text="Remote-IP" VerticalAlignment="Center" FontWeight="SemiBold" FontSize="11"/>
                <Border    Grid.Column="9"  Tag="RemoteIpWidth" Style="{StaticResource TelemetryColumnSplitterStyle}" ManipulationDelta="ColumnSplitter_ManipulationDelta" PointerEntered="ColumnSplitter_PointerEntered" PointerExited="ColumnSplitter_PointerExited">
                    <Rectangle Width="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}"/>
                </Border>
                <TextBlock Grid.Column="10" Text="Land"      VerticalAlignment="Center" FontWeight="SemiBold" FontSize="11"/>
                <Border    Grid.Column="11" Tag="CountryWidth" Style="{StaticResource TelemetryColumnSplitterStyle}" ManipulationDelta="ColumnSplitter_ManipulationDelta" PointerEntered="ColumnSplitter_PointerEntered" PointerExited="ColumnSplitter_PointerExited">
                    <Rectangle Width="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}"/>
                </Border>
                <TextBlock Grid.Column="12" Text="Treffer"   VerticalAlignment="Center" FontWeight="SemiBold" FontSize="11"/>
                <Border    Grid.Column="13" Tag="HitsWidth"   Style="{StaticResource TelemetryColumnSplitterStyle}" ManipulationDelta="ColumnSplitter_ManipulationDelta" PointerEntered="ColumnSplitter_PointerEntered" PointerExited="ColumnSplitter_PointerExited">
                    <Rectangle Width="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}"/>
                </Border>
                <TextBlock Grid.Column="14" Text="Bytes"     VerticalAlignment="Center" FontWeight="SemiBold" FontSize="11"/>
                <Border    Grid.Column="15" Tag="BytesWidth"   Style="{StaticResource TelemetryColumnSplitterStyle}" ManipulationDelta="ColumnSplitter_ManipulationDelta" PointerEntered="ColumnSplitter_PointerEntered" PointerExited="ColumnSplitter_PointerExited">
                    <Rectangle Width="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}"/>
                </Border>
                <TextBlock Grid.Column="16" Text="Zuletzt"   VerticalAlignment="Center" FontWeight="SemiBold" FontSize="11"/>
            </Grid>
        </Border>

        <!-- ═════════════════════════════════════════════════════════════
             Tabelle (oder Leer-Zustand)
             ═════════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="3">

            <!-- Leer-Zustand -->
            <StackPanel
                Visibility="{x:Bind ViewModel.EmptyStateVisibility, Mode=OneWay}"
                VerticalAlignment="Center" HorizontalAlignment="Center"
                Spacing="12" MaxWidth="460">
                <FontIcon Glyph="&#xE9D5;" FontSize="56"
                          Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                          HorizontalAlignment="Center"/>
                <TextBlock Text="Noch keine Telemetrie-Verbindungen erkannt"
                           Style="{StaticResource SubtitleTextBlockStyle}"
                           HorizontalAlignment="Center"/>
                <TextBlock TextWrapping="WrapWholeWords" TextAlignment="Center"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           Style="{StaticResource BodyTextBlockStyle}">
                    Verbindungen zu Microsoft-Telemetrie-Endpunkten (DiagTrack, Windows Update, Defender, OneDrive …) werden hier in Echtzeit angezeigt. Die Aufzeichnung läuft im Hintergrund – sobald Windows einen passenden Endpunkt kontaktiert, erscheint er hier.
                </TextBlock>
                <TextBlock Text="Tipp: DNS-Auflösung benötigt Administrator-Rechte (ETW). Ohne sie werden Hosts nur per IP-Range erkannt."
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                           TextWrapping="WrapWholeWords" TextAlignment="Center"/>
            </StackPanel>

            <!-- Datentabelle -->
            <ListView
                x:Name="EntriesList"
                ItemsSource="{x:Bind ViewModel.Entries, Mode=OneWay}"
                Visibility="{x:Bind ViewModel.ContentVisibility, Mode=OneWay}"
                SelectionMode="Single"
                IsItemClickEnabled="False"
                ContextRequested="EntriesList_ContextRequested"
                Padding="0">

                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Padding"        Value="0"/>
                        <Setter Property="MinHeight"      Value="30"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        <Setter Property="BorderBrush"    Value="{ThemeResource DividerStrokeColorDefaultBrush}"/>
                    </Style>
                </ListView.ItemContainerStyle>

                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="vm:TelemetryEntryViewModel">
                        <Grid Margin="12,0,12,0" Height="30">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="{Binding Layout.ServiceWidth,  Source={StaticResource TelemetryColumnLayout}, Mode=OneWay}"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="{Binding Layout.HostnameWidth, Source={StaticResource TelemetryColumnLayout}, Mode=OneWay}"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="{Binding Layout.ProcessWidth,  Source={StaticResource TelemetryColumnLayout}, Mode=OneWay}"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="{Binding Layout.PidWidth,      Source={StaticResource TelemetryColumnLayout}, Mode=OneWay}"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="{Binding Layout.RemoteIpWidth, Source={StaticResource TelemetryColumnLayout}, Mode=OneWay}"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="{Binding Layout.CountryWidth,  Source={StaticResource TelemetryColumnLayout}, Mode=OneWay}"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="{Binding Layout.HitsWidth,     Source={StaticResource TelemetryColumnLayout}, Mode=OneWay}"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="{Binding Layout.BytesWidth,    Source={StaticResource TelemetryColumnLayout}, Mode=OneWay}"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="{Binding Layout.LastSeenWidth, Source={StaticResource TelemetryColumnLayout}, Mode=OneWay}"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Service-Badge mit Farbpunkt -->
                            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                <Border Width="8" Height="8" CornerRadius="4"
                                        Background="{x:Bind ServiceBadgeBrush, Mode=OneWay}"/>
                                <TextBlock Text="{x:Bind ServiceName, Mode=OneWay}" FontSize="12"
                                           FontWeight="SemiBold" TextTrimming="CharacterEllipsis"
                                           VerticalAlignment="Center"/>
                            </StackPanel>

                            <TextBlock Grid.Column="2" Text="{x:Bind HostnameDisplay, Mode=OneWay}"
                                       VerticalAlignment="Center" FontSize="12"
                                       TextTrimming="CharacterEllipsis"
                                       ToolTipService.ToolTip="{x:Bind Hostname, Mode=OneWay}"/>

                            <TextBlock Grid.Column="4" Text="{x:Bind ProcessName}"
                                       VerticalAlignment="Center" FontSize="12"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       TextTrimming="CharacterEllipsis"/>

                            <TextBlock Grid.Column="6" Text="{x:Bind ProcessId}"
                                       VerticalAlignment="Center" FontSize="11"
                                       Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>

                            <TextBlock Grid.Column="8" Text="{x:Bind RemoteIp}"
                                       VerticalAlignment="Center"
                                       FontFamily="Cascadia Code,Consolas,Courier New"
                                       FontSize="11"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       TextTrimming="CharacterEllipsis"/>

                            <TextBlock Grid.Column="10" Text="{x:Bind CountryCode, Mode=OneWay}"
                                       VerticalAlignment="Center" FontSize="11"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                            <TextBlock Grid.Column="12" Text="{x:Bind HitCount, Mode=OneWay}"
                                       VerticalAlignment="Center" FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>

                            <TextBlock Grid.Column="14" Text="{x:Bind BytesDisplay, Mode=OneWay}"
                                       VerticalAlignment="Center" FontSize="11"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                            <TextBlock Grid.Column="16" Text="{x:Bind LastSeenText, Mode=OneWay}"
                                       VerticalAlignment="Center" FontSize="11"
                                       FontFamily="Cascadia Code,Consolas,Courier New"
                                       Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>

        <!-- ═════════════════════════════════════════════════════════════
             Status-Leiste
             ═════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="4"
                Background="{ThemeResource LayerFillColorDefaultBrush}"
                BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                BorderThickness="0,1,0,0"
                Padding="16,6">
            <TextBlock Text="{x:Bind ViewModel.StatusText, Mode=OneWay}"
                       FontSize="11"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
        </Border>
    </Grid>
</Page>
