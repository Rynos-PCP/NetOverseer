<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="NetOverseer.App.Views.FirewallPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:NetOverseer.App.ViewModels">

    <Grid>
        <!-- Haupt-Layout -->
        <Grid RowDefinitions="Auto,Auto,*">

            <!-- ═══════════════ Admin-Warnung ═══════════════ -->
            <InfoBar Grid.Row="0"
                     x:Uid="Fw_AdminWarning"
                     IsOpen="{x:Bind ViewModel.ShowAdminWarning, Mode=OneWay}"
                     IsClosable="False"
                     Severity="Warning"
                     Title="Eingeschränkte Funktionalität"
                     Message="Firewall-Regeln können nur mit Administrator-Rechten verwaltet werden.">
                <InfoBar.ActionButton>
                    <Button x:Uid="Fw_RunAsAdmin"
                            Content="Als Administrator starten"
                            Command="{x:Bind ViewModel.RestartAsAdministratorCommand}"/>
                </InfoBar.ActionButton>
            </InfoBar>

            <!-- ═══════════════ Such-/Aktionsleiste ═══════════════ -->
            <Grid Grid.Row="1"
                  Padding="16,8"
                  ColumnDefinitions="*,Auto,Auto"
                  Background="{ThemeResource LayerFillColorDefaultBrush}"
                  BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                  BorderThickness="0,0,0,1">

                <AutoSuggestBox Grid.Column="0"
                                x:Uid="Fw_SearchBox"
                                PlaceholderText="Regeln suchen (Name, Pfad, IP) …"
                                Text="{x:Bind ViewModel.SearchText, Mode=TwoWay}"
                                QueryIcon="Find"
                                MaxWidth="400"
                                HorizontalAlignment="Left"/>

                <Button Grid.Column="1"
                        x:Uid="Fw_RefreshButton"
                        Margin="8,0,0,0"
                        Command="{x:Bind ViewModel.RefreshCommand}"
                        ToolTipService.ToolTip="Aktualisieren">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE72C;" FontSize="14"/>
                        <TextBlock x:Uid="Fw_RefreshLabel" Text="Aktualisieren"/>
                    </StackPanel>
                </Button>

                <TextBlock Grid.Column="2"
                           Margin="16,0,0,0"
                           VerticalAlignment="Center"
                           Text="{x:Bind ViewModel.StatusText, Mode=OneWay}"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            </Grid>

            <!-- ═══════════════ Tabs ═══════════════ -->
            <TabView Grid.Row="2"
                     IsAddTabButtonVisible="False"
                     TabWidthMode="SizeToContent"
                     SelectionChanged="TabView_SelectionChanged">

                <!-- ─── Tab 1: NetOverseer-Regeln ─── -->
                <TabViewItem x:Uid="Fw_TabNetOverseer" Header="NetOverseer-Regeln" IsClosable="False">
                    <!-- Äußeres Single-Cell-Grid: garantiert volle Stretch-Fläche für Empty-State -->
                    <Grid HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                    <Grid RowDefinitions="Auto,Auto,*">
                        <!-- Spalten-Header -->
                        <Grid Grid.Row="0"
                              Padding="12,6"
                              ColumnDefinitions="30,*,90,70,130,56,40,40"
                              Background="{ThemeResource LayerFillColorAltBrush}"
                              BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                              BorderThickness="0,0,0,1">
                            <TextBlock Grid.Column="1" x:Uid="Fw_ColRuleName" Text="REGELNAME"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <TextBlock Grid.Column="2" x:Uid="Fw_ColAction" Text="AKTION"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <TextBlock Grid.Column="3" x:Uid="Fw_ColProtocol" Text="PROTOKOLL"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <TextBlock Grid.Column="4" x:Uid="Fw_ColTarget" Text="ZIEL"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <TextBlock Grid.Column="5" x:Uid="Fw_ColActive" Text="AKTIV"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </Grid>

                        <!-- Lade-Indikator -->
                        <ProgressBar Grid.Row="1"
                                     IsIndeterminate="True"
                                     Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay}"/>

                        <!-- Liste -->
                        <ListView Grid.Row="2"
                                  ItemsSource="{x:Bind ViewModel.NetOverseerRules, Mode=OneWay}"
                                  SelectionMode="None">
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="Padding" Value="0"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    </Style>
                                </ListView.ItemContainerStyle>
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="vm:FirewallRuleItemViewModel">
                                        <Grid ColumnDefinitions="30,*,90,70,130,56,40,40"
                                              Padding="12,8"
                                              BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                                              BorderThickness="0,0,0,1">
                                            <FontIcon Grid.Column="0"
                                                      Glyph="{x:Bind DirectionGlyph}"
                                                      FontSize="14"
                                                      ToolTipService.ToolTip="{x:Bind DirectionTooltip}"
                                                      Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                            <TextBlock Grid.Column="1"
                                                       Text="{x:Bind DisplayName, Mode=OneWay}"
                                                       VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis"
                                                       ToolTipService.ToolTip="{x:Bind DisplayName, Mode=OneWay}"/>
                                            <Border Grid.Column="2"
                                                    Background="{x:Bind ActionChipBackground, Mode=OneWay}"
                                                    CornerRadius="4"
                                                    Padding="8,2"
                                                    HorizontalAlignment="Left"
                                                    VerticalAlignment="Center">
                                                <TextBlock Text="{x:Bind ActionDisplay, Mode=OneWay}"
                                                           Foreground="{x:Bind ActionChipForeground, Mode=OneWay}"
                                                           FontSize="11"
                                                           FontWeight="SemiBold"/>
                                            </Border>
                                            <TextBlock Grid.Column="3"
                                                       Text="{x:Bind ProtocolDisplay, Mode=OneWay}"
                                                       VerticalAlignment="Center"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                            <TextBlock Grid.Column="4"
                                                       Text="{x:Bind RemoteAddressDisplay, Mode=OneWay}"
                                                       VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis"
                                                       FontFamily="Consolas"/>
                                            <ToggleSwitch Grid.Column="5"
                                                          IsOn="{x:Bind IsEnabled, Mode=TwoWay}"
                                                          OnContent=""
                                                          OffContent=""
                                                          MinWidth="0"
                                                          VerticalAlignment="Center"/>
                                            <Button Grid.Column="6"
                                                    x:Uid="Fw_EditRuleTooltip"
                                                    Command="{x:Bind EditCommand}"
                                                    Style="{StaticResource SubtleButtonStyle}"
                                                    VerticalAlignment="Center"
                                                    ToolTipService.ToolTip="Regel bearbeiten">
                                                <FontIcon Glyph="&#xE70F;" FontSize="12"/>
                                            </Button>
                                            <Button Grid.Column="7"
                                                    x:Uid="Fw_RemoveRuleTooltip"
                                                    Command="{x:Bind RemoveCommand}"
                                                    Style="{StaticResource SubtleButtonStyle}"
                                                    VerticalAlignment="Center"
                                                    ToolTipService.ToolTip="Regel entfernen">
                                                <FontIcon Glyph="&#xE74D;" FontSize="12"/>
                                            </Button>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                    </Grid>

                            <!-- Empty-State (zentriert über gesamte Tab-Fläche) -->
                            <StackPanel HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Spacing="10"
                                        Visibility="{x:Bind ViewModel.HasNoNetOverseerRules, Mode=OneWay}">
                                <FontIcon Glyph="&#xE945;" FontSize="56"
                                          Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                                <TextBlock x:Uid="Fw_EmptyNetOverseerTitle" Text="Keine NetOverseer-Regeln vorhanden"
                                           Style="{StaticResource SubtitleTextBlockStyle}"
                                           HorizontalAlignment="Center"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <TextBlock x:Uid="Fw_EmptyNetOverseerHint" Text="Blockieren Sie Anwendungen über die Live-Verbindungen, um eigene Regeln zu erstellen."
                                           HorizontalAlignment="Center"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap"
                                           MaxWidth="380"
                                           Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                            </StackPanel>
                    </Grid>
                </TabViewItem>

                <!-- ─── Tab 2: Verwaiste Regeln ─── -->
                <TabViewItem x:Uid="Fw_TabOrphaned" Header="Verwaiste Regeln" IsClosable="False">
                    <Grid HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                    <Grid RowDefinitions="Auto,*">
                        <ListView Grid.Row="1"
                                  ItemsSource="{x:Bind ViewModel.OrphanedRules, Mode=OneWay}"
                                  SelectionMode="None">
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="Padding" Value="0"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    </Style>
                                </ListView.ItemContainerStyle>
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="vm:FirewallRuleItemViewModel">
                                        <Grid ColumnDefinitions="*,90,Auto,Auto"
                                              Padding="16,8"
                                              BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                                              BorderThickness="0,0,0,1">
                                            <StackPanel Grid.Column="0" Spacing="2">
                                                <TextBlock Text="{x:Bind DisplayName, Mode=OneWay}"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{x:Bind RemoteAddressDisplay, Mode=OneWay}"
                                                           Style="{StaticResource CaptionTextBlockStyle}"
                                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                            </StackPanel>
                                            <Border Grid.Column="1"
                                                    Background="{x:Bind ActionChipBackground, Mode=OneWay}"
                                                    CornerRadius="4"
                                                    Padding="8,2"
                                                    HorizontalAlignment="Left"
                                                    VerticalAlignment="Center">
                                                <TextBlock Text="{x:Bind ActionDisplay, Mode=OneWay}"
                                                           Foreground="{x:Bind ActionChipForeground, Mode=OneWay}"
                                                           FontSize="11"
                                                           FontWeight="SemiBold"/>
                                            </Border>
                                            <Button Grid.Column="2"
                                                    x:Uid="Fw_EditButton"
                                                    Command="{x:Bind EditCommand}"
                                                    Margin="6,0,0,0"
                                                    Content="Bearbeiten"/>
                                            <Button Grid.Column="3"
                                                    x:Uid="Fw_RemoveButton"
                                                    Command="{x:Bind RemoveCommand}"
                                                    Margin="6,0,0,0"
                                                    Content="Entfernen"
                                                    Style="{StaticResource AccentButtonStyle}"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                    </Grid>

                            <!-- Empty-State -->
                            <StackPanel HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Spacing="10"
                                        Visibility="{x:Bind ViewModel.HasNoOrphanedRules, Mode=OneWay}">
                                <FontIcon Glyph="&#xE73E;" FontSize="56"
                                          Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                                <TextBlock x:Uid="Fw_EmptyOrphanedTitle" Text="Keine verwaisten Regeln"
                                           Style="{StaticResource SubtitleTextBlockStyle}"
                                           HorizontalAlignment="Center"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <TextBlock x:Uid="Fw_EmptyOrphanedHint" Text="Alle Firewall-Regeln verweisen auf vorhandene Anwendungen."
                                           HorizontalAlignment="Center"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap"
                                           MaxWidth="380"
                                           Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                            </StackPanel>
                    </Grid>
                </TabViewItem>

                <!-- ─── Tab 3: Alle Regeln ─── -->
                <TabViewItem x:Name="AllRulesTab" x:Uid="Fw_TabAllRules" Header="Alle Regeln" IsClosable="False">
                    <Grid HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                    <Grid RowDefinitions="Auto,Auto,*">
                        <InfoBar Grid.Row="0"
                                 x:Uid="Fw_AllRulesInfo"
                                 IsOpen="True"
                                 IsClosable="False"
                                 Severity="Informational"
                                 Message="Alle Windows-Firewall-Regeln gruppiert nach Anwendung. Regeln erscheinen während des Ladens."/>

                        <ProgressBar Grid.Row="1"
                                     IsIndeterminate="True"
                                     Visibility="{x:Bind ViewModel.IsLoadingAll, Mode=OneWay}"/>

                        <ScrollViewer Grid.Row="2"
                                      HorizontalScrollMode="Disabled"
                                      HorizontalScrollBarVisibility="Disabled">
                            <ItemsControl ItemsSource="{x:Bind ViewModel.AllGroups, Mode=OneWay}"
                                          HorizontalAlignment="Stretch"
                                          HorizontalContentAlignment="Stretch"
                                          Padding="8,4">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:FirewallAppGroupViewModel">
                                            <Expander HorizontalAlignment="Stretch"
                                                      HorizontalContentAlignment="Stretch"
                                                      Margin="0,2"
                                                      IsExpanded="False">
                                                <Expander.Header>
                                                    <Grid ColumnDefinitions="*,Auto" Padding="0,4">
                                                        <StackPanel Grid.Column="0" Spacing="2">
                                                            <TextBlock Text="{x:Bind AppDisplayName}"
                                                                       Style="{StaticResource BodyStrongTextBlockStyle}"/>
                                                            <TextBlock Text="{x:Bind RuleSummary}"
                                                                       Style="{StaticResource CaptionTextBlockStyle}"
                                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                                        </StackPanel>
                                                        <Border Grid.Column="1"
                                                                Background="{ThemeResource SystemFillColorCautionBackgroundBrush}"
                                                                CornerRadius="4"
                                                                Padding="6,2"
                                                                Margin="8,0,0,0"
                                                                VerticalAlignment="Center"
                                                                Visibility="{x:Bind IsOrphaned}">
                                                            <TextBlock x:Uid="Fw_OrphanedBadge" Text="Verwaist" FontSize="10"/>
                                                        </Border>
                                                    </Grid>
                                                </Expander.Header>

                                                <ItemsControl ItemsSource="{x:Bind Rules, Mode=OneWay}"
                                                              HorizontalAlignment="Stretch"
                                                              HorizontalContentAlignment="Stretch">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate x:DataType="vm:FirewallRuleItemViewModel">
                                                            <Grid ColumnDefinitions="24,*,80,60,140,50,36,36"
                                                                  Padding="8,6"
                                                                  BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                                                                  BorderThickness="0,0,0,1">
                                                                <FontIcon Grid.Column="0"
                                                                          Glyph="{x:Bind DirectionGlyph}"
                                                                          FontSize="12"
                                                                          Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                                                <TextBlock Grid.Column="1"
                                                                           Text="{x:Bind DisplayName, Mode=OneWay}"
                                                                           VerticalAlignment="Center"
                                                                           TextTrimming="CharacterEllipsis"
                                                                           FontSize="13"/>
                                                                <Border Grid.Column="2"
                                                                        Background="{x:Bind ActionChipBackground, Mode=OneWay}"
                                                                        CornerRadius="3"
                                                                        Padding="6,1"
                                                                        HorizontalAlignment="Left"
                                                                        VerticalAlignment="Center">
                                                                    <TextBlock Text="{x:Bind ActionDisplay, Mode=OneWay}"
                                                                               Foreground="{x:Bind ActionChipForeground, Mode=OneWay}"
                                                                               FontSize="10"
                                                                               FontWeight="SemiBold"/>
                                                                </Border>
                                                                <TextBlock Grid.Column="3"
                                                                           Text="{x:Bind ProtocolDisplay, Mode=OneWay}"
                                                                           VerticalAlignment="Center"
                                                                           FontSize="12"
                                                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                                                <TextBlock Grid.Column="4"
                                                                           Text="{x:Bind RemoteAddressDisplay, Mode=OneWay}"
                                                                           VerticalAlignment="Center"
                                                                           FontSize="12"
                                                                           FontFamily="Consolas"
                                                                           TextTrimming="CharacterEllipsis"/>
                                                                <ToggleSwitch Grid.Column="5"
                                                                              IsOn="{x:Bind IsEnabled, Mode=TwoWay}"
                                                                              OnContent=""
                                                                              OffContent=""
                                                                              MinWidth="0"
                                                                              VerticalAlignment="Center"/>
                                                                <Button Grid.Column="6"
                                                                        x:Uid="Fw_EditTooltipAll"
                                                                        Command="{x:Bind EditCommand}"
                                                                        Style="{StaticResource SubtleButtonStyle}"
                                                                        VerticalAlignment="Center"
                                                                        ToolTipService.ToolTip="Bearbeiten">
                                                                    <FontIcon Glyph="&#xE70F;" FontSize="11"/>
                                                                </Button>
                                                                <Button Grid.Column="7"
                                                                        x:Uid="Fw_RemoveTooltipAll"
                                                                        Command="{x:Bind RemoveCommand}"
                                                                        Style="{StaticResource SubtleButtonStyle}"
                                                                        VerticalAlignment="Center"
                                                                        ToolTipService.ToolTip="Entfernen">
                                                                    <FontIcon Glyph="&#xE74D;" FontSize="11"/>
                                                                </Button>
                                                            </Grid>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </Expander>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                    </Grid>

                        <!-- Empty-State (zentriert über gesamte Tab-Fläche) -->
                        <StackPanel HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Spacing="10"
                                    Visibility="{x:Bind ViewModel.HasNoAllRules, Mode=OneWay}">
                            <FontIcon Glyph="&#xE945;" FontSize="56"
                                      Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                            <TextBlock x:Uid="Fw_EmptyAllTitle" Text="Keine Firewall-Regeln gefunden"
                                       Style="{StaticResource SubtitleTextBlockStyle}"
                                       HorizontalAlignment="Center"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <TextBlock x:Uid="Fw_EmptyAllHint" Text="Passt der Suchfilter eventuell nicht zu vorhandenen Regeln?"
                                       HorizontalAlignment="Center"
                                       TextAlignment="Center"
                                       TextWrapping="Wrap"
                                       MaxWidth="380"
                                       Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                        </StackPanel>
                    </Grid>
                </TabViewItem>
            </TabView>
        </Grid>

        <!-- ═══════════════ Edit-Fly-In (Overlay) ═══════════════ -->
        <Grid x:Name="EditOverlay"
              Background="#80000000"
              Visibility="{x:Bind ViewModel.IsEditPaneOpen, Mode=OneWay}"
              Canvas.ZIndex="100">
            <Border HorizontalAlignment="Right"
                    VerticalAlignment="Stretch"
                    Width="460"
                    Background="{ThemeResource LayerFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1,0,0,0">
                <Grid RowDefinitions="Auto,*,Auto">
                    <!-- Header -->
                    <Grid Grid.Row="0"
                          Padding="20,16"
                          ColumnDefinitions="*,Auto"
                          BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                          BorderThickness="0,0,0,1">
                        <StackPanel Grid.Column="0" Spacing="2">
                            <TextBlock x:Uid="Fw_EditPaneTitle" Text="Regel bearbeiten"
                                       Style="{StaticResource SubtitleTextBlockStyle}"/>
                            <TextBlock x:Uid="Fw_EditPaneSubtitle" Text="Detail-Konfiguration der Firewall-Regel."
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                        <Button Grid.Column="1"
                                x:Uid="Fw_CloseTooltip"
                                Command="{x:Bind ViewModel.CancelEditCommand}"
                                Style="{StaticResource SubtleButtonStyle}"
                                ToolTipService.ToolTip="Schließen">
                            <FontIcon Glyph="&#xE711;" FontSize="14"/>
                        </Button>
                    </Grid>

                    <!-- Body -->
                    <ScrollViewer Grid.Row="1" Padding="20,12">
                        <StackPanel Spacing="12"
                                    DataContext="{x:Bind ViewModel.EditingRule, Mode=OneWay}">
                            <InfoBar IsOpen="{Binding HasEditError, Mode=OneWay}"
                                     Severity="Error"
                                     IsClosable="False"
                                     Message="{Binding EditErrorMessage, Mode=OneWay}"/>

                            <StackPanel Spacing="4">
                                <TextBlock x:Uid="Fw_FieldName" Text="Name" Style="{StaticResource CaptionTextBlockStyle}"/>
                                <TextBox Text="{Binding EditName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>

                            <StackPanel Spacing="4">
                                <TextBlock x:Uid="Fw_FieldDescription" Text="Beschreibung" Style="{StaticResource CaptionTextBlockStyle}"/>
                                <TextBox Text="{Binding EditDescription, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         MinHeight="60"/>
                            </StackPanel>

                            <StackPanel Spacing="4">
                                <TextBlock x:Uid="Fw_FieldAppPath" Text="Anwendungspfad (leer = global)" Style="{StaticResource CaptionTextBlockStyle}"/>
                                <TextBox Text="{Binding EditApplicationPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         FontFamily="Consolas"/>
                            </StackPanel>

                            <Grid ColumnDefinitions="*,12,*">
                                <StackPanel Grid.Column="0" Spacing="4">
                                    <TextBlock x:Uid="Fw_FieldDirection" Text="Richtung" Style="{StaticResource CaptionTextBlockStyle}"/>
                                    <ComboBox SelectedIndex="{Binding EditDirectionIndex, Mode=TwoWay}"
                                              HorizontalAlignment="Stretch">
                                        <ComboBoxItem x:Uid="Fw_DirectionInbound" Content="Eingehend"/>
                                        <ComboBoxItem x:Uid="Fw_DirectionOutbound" Content="Ausgehend"/>
                                    </ComboBox>
                                </StackPanel>
                                <StackPanel Grid.Column="2" Spacing="4">
                                    <TextBlock x:Uid="Fw_FieldAction" Text="Aktion" Style="{StaticResource CaptionTextBlockStyle}"/>
                                    <ComboBox SelectedIndex="{Binding EditActionIndex, Mode=TwoWay}"
                                              HorizontalAlignment="Stretch">
                                        <ComboBoxItem x:Uid="Fw_ActionAllow" Content="Erlauben"/>
                                        <ComboBoxItem x:Uid="Fw_ActionBlock" Content="Blockieren"/>
                                    </ComboBox>
                                </StackPanel>
                            </Grid>

                            <StackPanel Spacing="4">
                                <TextBlock x:Uid="Fw_FieldProtocol" Text="Protokoll" Style="{StaticResource CaptionTextBlockStyle}"/>
                                <ComboBox SelectedIndex="{Binding EditProtocolIndex, Mode=TwoWay}"
                                          HorizontalAlignment="Stretch">
                                    <ComboBoxItem x:Uid="Fw_ProtocolAll" Content="Alle"/>
                                    <ComboBoxItem Content="TCP"/>
                                    <ComboBoxItem Content="UDP"/>
                                    <ComboBoxItem Content="ICMP"/>
                                </ComboBox>
                            </StackPanel>

                            <Grid ColumnDefinitions="*,12,*">
                                <StackPanel Grid.Column="0" Spacing="4">
                                    <TextBlock x:Uid="Fw_FieldLocalPorts" Text="Lokale Ports" Style="{StaticResource CaptionTextBlockStyle}"/>
                                    <TextBox x:Uid="Fw_LocalPortsPlaceholder" Text="{Binding EditLocalPorts, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             PlaceholderText="* oder 80,443"
                                             FontFamily="Consolas"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2" Spacing="4">
                                    <TextBlock x:Uid="Fw_FieldRemotePorts" Text="Remote-Ports" Style="{StaticResource CaptionTextBlockStyle}"/>
                                    <TextBox x:Uid="Fw_RemotePortsPlaceholder" Text="{Binding EditRemotePorts, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             PlaceholderText="* oder 443"
                                             FontFamily="Consolas"/>
                                </StackPanel>
                            </Grid>

                            <StackPanel Spacing="4">
                                <TextBlock x:Uid="Fw_FieldRemoteAddresses" Text="Remote-Adressen" Style="{StaticResource CaptionTextBlockStyle}"/>
                                <TextBox x:Uid="Fw_RemoteAddressesPlaceholder" Text="{Binding EditRemoteAddresses, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         PlaceholderText="* oder 1.2.3.4, 10.0.0.0/8"
                                         FontFamily="Consolas"/>
                            </StackPanel>

                            <ToggleSwitch x:Uid="Fw_RuleActiveToggle"
                                          Header="Regel aktiv"
                                          IsOn="{Binding EditIsEnabled, Mode=TwoWay}"
                                          OnContent="Ein"
                                          OffContent="Aus"/>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Footer -->
                    <Grid Grid.Row="2"
                          Padding="20,12"
                          ColumnDefinitions="*,Auto,Auto"
                          BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                          BorderThickness="0,1,0,0">
                        <Button Grid.Column="1"
                                x:Uid="Fw_CancelButton"
                                Content="Abbrechen"
                                Command="{x:Bind ViewModel.CancelEditCommand}"/>
                        <Button Grid.Column="2"
                                x:Uid="Fw_SaveButton"
                                Margin="8,0,0,0"
                                Content="Speichern"
                                Style="{StaticResource AccentButtonStyle}"
                                Command="{x:Bind ViewModel.SaveEditCommand}"/>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
