<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="NetOverseer.App.Views.BlockConfirmationDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    x:Uid="BlockDialog"
    Title="Verbindung blockieren"
    PrimaryButtonText="Blockieren"
    CloseButtonText="Abbrechen"
    DefaultButton="Close">

    <StackPanel Spacing="16" MinWidth="360" MaxWidth="440">

        <!-- Verbindungs-Info -->
        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="16,12">
            <StackPanel Spacing="4">
                <TextBlock x:Name="ProcessInfoText"
                           Style="{StaticResource BodyStrongTextBlockStyle}"
                           TextWrapping="Wrap"/>
                <TextBlock x:Name="RemoteInfoText"
                           Style="{StaticResource BodyTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <!-- Block-Art wählen -->
        <TextBlock x:Uid="BlockDialog_Question" Text="Was soll blockiert werden?"
                   Style="{StaticResource BodyStrongTextBlockStyle}"/>

        <RadioButtons x:Name="BlockModeGroup" SelectedIndex="0">
            <RadioButton x:Name="RadioIpOnly" x:Uid="BlockDialog_IpOnly"
                         Content="Nur diese IP-Adresse"/>
            <RadioButton x:Name="RadioAppOnly" x:Uid="BlockDialog_AppOnly"
                         Content="Gesamte Anwendung (alle Verbindungen)"/>
            <RadioButton x:Name="RadioAppAndIp" x:Uid="BlockDialog_AppAndIp"
                         Content="Anwendung + diese IP (doppelte Sperre)"/>
        </RadioButtons>

        <!-- Systemapp-Warnung (wird programmatisch ein-/ausgeblendet) -->
        <InfoBar x:Name="SystemAppWarning" x:Uid="BlockDialog_SystemWarning"
                 IsOpen="False"
                 IsClosable="False"
                 Severity="Warning"
                 Title="System-Anwendung"
                 Message="Diese Anwendung ist eine Windows-Systemkomponente. Das Blockieren kann die Systemstabilität oder Windows Update beeinträchtigen."/>

        <!-- Admin-Warnung (sichtbar wenn nicht als Admin) -->
        <InfoBar x:Name="AdminWarning" x:Uid="BlockDialog_AdminWarning"
                 IsOpen="False"
                 IsClosable="False"
                 Severity="Informational"
                 Title="Administrator-Rechte erforderlich"
                 Message="Firewall-Regeln können nur mit Administrator-Rechten erstellt werden."/>

    </StackPanel>
</ContentDialog>
